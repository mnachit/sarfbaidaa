    @Override
    public CreditDashboardDTO getCreditDashboardFiltered(Company company, Long currentUserId,
                                                         String status, String currency, String startDate, String endDate, String search) {
        List<Loan> allLoans = loanRepository.findByCompany(company);

        LoanStatus statusFilter = null;
        if (status != null && !status.isBlank() && !"all".equalsIgnoreCase(status)) {
            try {
                statusFilter = LoanStatus.valueOf(status.toUpperCase());
            } catch (IllegalArgumentException ignored) {}
        }

        final LoanStatus finalStatusFilter = statusFilter;
        String currencyFilter = (currency != null && !currency.isBlank() && !"all".equalsIgnoreCase(currency)) ? currency : null;
        final String finalCurrencyFilter = currencyFilter;
        LocalDate start = parseDate(startDate);
        final LocalDate finalStart = start;
        LocalDate end = parseDate(endDate);
        final LocalDate finalEnd = end;
        final String searchLower = (search != null && !search.isBlank()) ? search.toLowerCase().trim() : null;

        List<Loan> filtered = allLoans.stream()
                .filter(l -> l.getCreatedBy() != null && l.getCreatedBy().getId().equals(currentUserId))
                .filter(l -> finalStatusFilter == null || l.getStatus() == finalStatusFilter)
                .filter(l -> finalCurrencyFilter == null || l.getCurrency().getCode().equalsIgnoreCase(finalCurrencyFilter))
                .filter(l -> finalStart == null || !l.getIssueDate().isBefore(finalStart))
                .filter(l -> finalEnd == null || (l.getDueDate() != null && !l.getDueDate().isAfter(finalEnd)))
                .filter(l -> searchLower == null || 
                        (l.getClient().getFullName() != null && l.getClient().getFullName().toLowerCase().contains(searchLower)) ||
                        (l.getClient().getCin() != null && l.getClient().getCin().toLowerCase().contains(searchLower)) ||
                        (l.getClient().getEmail() != null && l.getClient().getEmail().toLowerCase().contains(searchLower)) ||
                        (l.getClient().getPhoneNumber() != null && l.getClient().getPhoneNumber().contains(searchLower)))
                .collect(Collectors.toList());

        BigDecimal totalCredit = filtered.stream().map(Loan::getAmount).reduce(BigDecimal.ZERO, BigDecimal::add);
        BigDecimal totalPaid = filtered.stream()
                .map(l -> (l.getStatus() == LoanStatus.REPAID || l.getStatus() == LoanStatus.CANCELED)
                        ? l.getAmount()
                        : (l.getPaidAmount() != null ? l.getPaidAmount() : BigDecimal.ZERO))
                .reduce(BigDecimal.ZERO, BigDecimal::add);
        BigDecimal totalUnpaid = totalCredit.subtract(totalPaid);

        double paidPct = totalCredit.compareTo(BigDecimal.ZERO) == 0 ? 0 : totalPaid.divide(totalCredit, 4, RoundingMode.HALF_UP).doubleValue() * 100;
        double unpaidPct = 100 - paidPct;

        Map<String, BigDecimal> loanedByCurrency = new HashMap<>();
        Map<String, BigDecimal> paidByCurrency = new HashMap<>();
        Map<String, BigDecimal> remainingByCurrency = new HashMap<>();
        Map<String, Integer> countByCurrency = new HashMap<>();
        for (Loan l : filtered) {
            String code = l.getCurrency().getCode();
            BigDecimal amount = l.getAmount();
            BigDecimal paid = (l.getStatus() == LoanStatus.REPAID || l.getStatus() == LoanStatus.CANCELED)
                    ? amount
                    : (l.getPaidAmount() != null ? l.getPaidAmount() : BigDecimal.ZERO);
            BigDecimal remaining = amount.subtract(paid);
            loanedByCurrency.merge(code, amount, BigDecimal::add);
            paidByCurrency.merge(code, paid, BigDecimal::add);
            remainingByCurrency.merge(code, remaining, BigDecimal::add);
            countByCurrency.merge(code, 1, Integer::sum);
        }

        List<CurrencyBreakdownDTO> currencyBreakdown = loanedByCurrency.keySet().stream()
                .map(code -> new CurrencyBreakdownDTO(
                        code,
                        remainingByCurrency.getOrDefault(code, BigDecimal.ZERO),
                        countByCurrency.getOrDefault(code, 0),
                        loanedByCurrency.getOrDefault(code, BigDecimal.ZERO),
                        paidByCurrency.getOrDefault(code, BigDecimal.ZERO),
                        remainingByCurrency.getOrDefault(code, BigDecimal.ZERO)))
                .collect(Collectors.toList());

        Map<Long, UserCreditSummaryDTO> clientSummaries = new HashMap<>();
        for (Loan l : filtered) {
            LoanClient c = l.getClient();
            if (!clientSummaries.containsKey(c.getId())) {
                List<Loan> clientLoans = filtered.stream().filter(ln -> ln.getClient().getId().equals(c.getId())).collect(Collectors.toList());
                BigDecimal clientTotal = clientLoans.stream().map(Loan::getAmount).reduce(BigDecimal.ZERO, BigDecimal::add);
                BigDecimal clientPaid = clientLoans.stream()
                        .map(ln -> (ln.getStatus() == LoanStatus.REPAID || ln.getStatus() == LoanStatus.CANCELED)
                                ? ln.getAmount()
                                : (ln.getPaidAmount() != null ? ln.getPaidAmount() : BigDecimal.ZERO))
                        .reduce(BigDecimal.ZERO, BigDecimal::add);
                BigDecimal clientUnpaid = clientTotal.subtract(clientPaid);
                int progress = clientTotal.compareTo(BigDecimal.ZERO) == 0 ? 100 : clientPaid.multiply(BigDecimal.valueOf(100)).divide(clientTotal, 0, RoundingMode.HALF_UP).intValue();
                String st = clientLoans.stream().anyMatch(ln -> ln.getStatus() == LoanStatus.OVERDUE) ? "overdue" :
                        clientLoans.stream().anyMatch(ln -> ln.getStatus() == LoanStatus.ACTIVE) ? "active" : "repaid";
                int activeCount = (int) clientLoans.stream().filter(ln -> ln.getStatus() == LoanStatus.ACTIVE).count();
                int overdueCount = (int) clientLoans.stream().filter(ln -> ln.getStatus() == LoanStatus.OVERDUE).count();

                clientSummaries.put(c.getId(), new UserCreditSummaryDTO(
                        c.getId(), c.getFullName(), c.getEmail(), c.getPhoneNumber(), c.getCin(),
                        clientTotal, clientPaid, clientUnpaid, clientLoans.size(), activeCount, overdueCount, progress, st));
            }
        }

        return new CreditDashboardDTO(
                totalCredit, totalPaid, totalUnpaid, paidPct, unpaidPct,
                (int) clientSummaries.values().stream().map(UserCreditSummaryDTO::getId).distinct().count(),
                filtered.size(),
                (int) clientSummaries.values().stream().filter(u -> "active".equals(u.getStatus())).count(),
                (int) filtered.stream().filter(l -> l.getStatus() == LoanStatus.ACTIVE).count(),
                (int) filtered.stream().filter(l -> l.getStatus() == LoanStatus.OVERDUE).count(),
                currencyBreakdown,
                new ArrayList<>(clientSummaries.values())
        );
    }

