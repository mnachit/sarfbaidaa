    private final LoanPaymentRepository loanPaymentRepository;
    private final CurrencyRepository currencyRepository;
    private final UserRepository userRepository;
    private final BalanceRepository balanceRepository;
    private final BalanceLoanRepository balanceLoanRepository;

    /**
     * Validates that the user is the owner (creator) of the loan.
     * Throws ValidationException if user is not authorized.
     */
    private void validateLoanOwnership(Loan loan, Long userId) {
        if (loan.getCreatedBy() == null || !loan.getCreatedBy().getId().equals(userId)) {
            log.warn("Unauthorized access attempt - Loan ID: {} | User ID: {} | Owner ID: {}", 
                    loan.getId(), userId, loan.getCreatedBy() != null ? loan.getCreatedBy().getId() : "null");
            throw new ValidationException(List.of(
                    ErrorMessage.builder()
                            .status(403)
                            .messageFr("Vous n'êtes pas autorisé à accéder à ce crédit")
                            .messageEn("You are not authorized to access this loan")
                            .build()));
        }
    }

    /**
     * Fetches a loan and validates ownership in one step.
     */
    private Loan getLoanWithOwnershipCheck(Long loanId, Company company, Long userId) {
        Loan loan = loanRepository.findById(loanId)
                .filter(l -> l.getCompany().getId().equals(company.getId()))
                .orElseThrow(() -> new ValidationException(List.of(
                        ErrorMessage.builder().status(404).messageFr("Crédit non trouvé").messageEn("Loan not found").build())));
        validateLoanOwnership(loan, userId);
        return loan;
    }

    @Override
    @Transactional
    public LoanResponse createLoan(LoanRequest request, Company company, Long createdByUserId) {
        log.info("Creating loan - Client ID: {} | Amount: {} | Currency ID: {} | Company: {} | Created by: {}", 
                request.getClientId(), request.getAmount(), request.getCurrencyId(), company.getId(), createdByUserId);
        
        LoanClient client = loanClientRepository.findByIdAndCompanyId(request.getClientId(), company.getId())
                .orElseThrow(() -> {
                    log.warn("Loan creation failed - Client not found: {}", request.getClientId());
                    return new ValidationException(List.of(
                        ErrorMessage.builder().status(404).messageFr("Client non trouvé").messageEn("Client not found").build()));
                });

        Currency currency = currencyRepository.findById(request.getCurrencyId())
                .orElseThrow(() -> {
                    log.warn("Loan creation failed - Currency not found: {}", request.getCurrencyId());
                    return new ValidationException(List.of(
                        ErrorMessage.builder().status(404).messageFr("Devise non trouvée").messageEn("Currency not found").build()));
                });

        // Only validate date order if dueDate is provided
        if (request.getDueDate() != null && request.getIssueDate().isAfter(request.getDueDate())) {
            log.warn("Loan creation failed - Invalid dates | Issue: {} | Due: {}", request.getIssueDate(), request.getDueDate());
            throw new ValidationException(List.of(
                    ErrorMessage.builder().status(400).messageFr("La date d'échéance doit être après la date d'émission").messageEn("Due date must be after issue date").build()));
        }

        // Convert currency code to enum for Balance lookup
        com.exchange.currencyexchangebackend.model.enums.Currency currencyEnum;
        try {
            currencyEnum = com.exchange.currencyexchangebackend.model.enums.Currency.valueOf(currency.getCode());
        } catch (IllegalArgumentException e) {
            throw new ValidationException(List.of(
                    ErrorMessage.builder().status(400).messageFr("Devise non supportée: " + currency.getCode()).messageEn("Unsupported currency: " + currency.getCode()).build()));
        }

        // Check user balance and deduct amount
        Optional<Balance> userBalance = balanceRepository.findByCurrencyAndUserId(currencyEnum, createdByUserId);
        BigDecimal availableBalance = userBalance.map(Balance::getBalanceAmount).orElse(BigDecimal.ZERO);
        
        if (availableBalance.compareTo(request.getAmount()) < 0) {
            log.warn("Loan creation failed - Insufficient balance | User: {} | Currency: {} | Required: {} | Available: {}", 
                    createdByUserId, currency.getCode(), request.getAmount(), availableBalance);
            throw new ValidationException(List.of(
                    ErrorMessage.builder()
                            .status(400)
                            .messageFr("Solde insuffisant en " + currency.getCode() + ". Disponible: " + availableBalance + ", Requis: " + request.getAmount())
                            .messageEn("Insufficient balance in " + currency.getCode() + ". Available: " + availableBalance + ", Required: " + request.getAmount())
                            .build()));
        }

        // Deduct from user balance
        Balance balance = userBalance.get();
        balance.setBalanceAmount(balance.getBalanceAmount().subtract(request.getAmount()));
        balanceRepository.save(balance);
        log.info("Deducted {} {} from user {} balance. New balance: {}", 
                request.getAmount(), currency.getCode(), createdByUserId, balance.getBalanceAmount());

        // Add to client's BalanceLoan
        BalanceLoan clientBalanceLoan = balanceLoanRepository.findByClientAndCurrency(client, currency)
                .orElse(BalanceLoan.builder()
                        .client(client)
                        .currency(currency)
                        .company(company)
                        .balanceAmount(BigDecimal.ZERO)
                        .build());
        clientBalanceLoan.setBalanceAmount(clientBalanceLoan.getBalanceAmount().add(request.getAmount()));
        balanceLoanRepository.save(clientBalanceLoan);
        log.info("Added {} {} to client {} balance_loan. New balance: {}", 
                request.getAmount(), currency.getCode(), client.getFullName(), clientBalanceLoan.getBalanceAmount());

        LoanStatus status = resolveStatus(request.getIssueDate(), request.getDueDate(), request.getStatus());
        User createdBy = createdByUserId != null ? userRepository.findById(createdByUserId).orElse(null) : null;

        Loan loan = Loan.builder()
                .client(client)
                .currency(currency)
                .amount(request.getAmount())
                .paidAmount(BigDecimal.ZERO)
                .loanType(request.getLoanType())
                .lenderName(request.getLenderName())
                .exchangeRate(request.getExchangeRate())
                .issueDate(request.getIssueDate())
                .dueDate(request.getDueDate())
                .status(status)
                .interestRate(request.getInterestRate() != null ? request.getInterestRate() : BigDecimal.ZERO)
                .collateral(request.getCollateral())
                .notes(request.getNotes())
                .isConfidential(request.getIsConfidential() != null ? request.getIsConfidential() : false)
                .company(company)
                .createdBy(createdBy)
                .build();

        loan = loanRepository.save(loan);
        log.info("Loan created successfully - ID: {} | Amount: {} | Client: {} | Status: {}", 
                loan.getId(), loan.getAmount(), client.getFullName(), status);
        return toLoanResponse(loan);
    }

    @Override
    @Transactional
    public LoanResponse updateLoan(Long loanId, LoanRequest request, Company company, Long userId) {
        log.info("Updating loan - ID: {} | New amount: {} | Company: {} | UserId: {}", loanId, request.getAmount(), company.getId(), userId);
        
        // Fetch loan and validate ownership
        Loan loan = getLoanWithOwnershipCheck(loanId, company, userId);

        LoanClient client = loanClientRepository.findByIdAndCompanyId(request.getClientId(), company.getId())
                .orElseThrow(() -> new ValidationException(List.of(
                        ErrorMessage.builder().status(404).messageFr("Client non trouvé").messageEn("Client not found").build())));

        Currency currency = currencyRepository.findById(request.getCurrencyId())
                .orElseThrow(() -> new ValidationException(List.of(
                        ErrorMessage.builder().status(404).messageFr("Devise non trouvée").messageEn("Currency not found").build())));

        // Only validate date order if dueDate is provided
        if (request.getDueDate() != null && request.getIssueDate().isAfter(request.getDueDate())) {
            throw new ValidationException(List.of(
                    ErrorMessage.builder().status(400).messageFr("La date d'échéance doit être après la date d'émission").messageEn("Due date must be after issue date").build()));
        }

        // ========== HANDLE STATUS CHANGE AND BALANCE TRANSFERS ==========
        LoanStatus oldStatus = loan.getStatus();
        LoanStatus newStatus;
        if (request.getStatus() != null && !request.getStatus().isBlank()) {
            newStatus = LoanStatus.valueOf(request.getStatus().toUpperCase());
        } else {
            newStatus = resolveStatus(request.getIssueDate(), request.getDueDate(), null);
        }
        
        // Handle balance changes if status changed AND userId is provided
        if (userId != null && oldStatus != newStatus) {
            BigDecimal amount = loan.getAmount().subtract(loan.getPaidAmount()); // Remaining amount
            
            // Convert currency code to enum for Balance lookup
            com.exchange.currencyexchangebackend.model.enums.Currency currencyEnum;
            try {
                currencyEnum = com.exchange.currencyexchangebackend.model.enums.Currency.valueOf(currency.getCode());
            } catch (IllegalArgumentException e) {
                throw new ValidationException(List.of(
                        ErrorMessage.builder().status(400).messageFr("Devise non supportée").messageEn("Unsupported currency").build()));
            }
            
            boolean isReturningMoney = (newStatus == LoanStatus.REPAID || newStatus == LoanStatus.CANCELED);
            boolean isReactivatingLoan = ((newStatus == LoanStatus.ACTIVE || newStatus == LoanStatus.OVERDUE) 
                                          && (oldStatus == LoanStatus.REPAID || oldStatus == LoanStatus.CANCELED));
            
            if (isReturningMoney) {
                // ========== CLIENT RETURNED MONEY (REPAID/CANCELED) ==========
                log.info("=== UPDATE LOAN STATUS: {} → {} | Client returns money ===", oldStatus, newStatus);
                
                // 1. Deduct from client's BalanceLoan
                BalanceLoan clientBalanceLoan = balanceLoanRepository.findByClientAndCurrency(loan.getClient(), loan.getCurrency())
                        .orElse(null);
                if (clientBalanceLoan != null) {
                    BigDecimal deductAmount = amount.min(clientBalanceLoan.getBalanceAmount());
                    clientBalanceLoan.setBalanceAmount(clientBalanceLoan.getBalanceAmount().subtract(deductAmount));
                    balanceLoanRepository.save(clientBalanceLoan);
                    log.info("✓ Deducted {} {} from client '{}' balance_loan. New: {}", 
                            deductAmount, currency.getCode(), loan.getClient().getFullName(), clientBalanceLoan.getBalanceAmount());
                }

                // 2. Add to user's Balance
                Optional<Balance> userBalance = balanceRepository.findByCurrencyAndUserId(currencyEnum, userId);
                if (userBalance.isPresent()) {
                    Balance balance = userBalance.get();
                    balance.setBalanceAmount(balance.getBalanceAmount().add(amount));
                    balanceRepository.save(balance);
                    log.info("✓ Added {} {} to user {} balance. New: {}", amount, currency.getCode(), userId, balance.getBalanceAmount());
                } else {
                    User user = userRepository.findById(userId).orElse(null);
                    if (user != null) {
                        Balance newBalance = new Balance();
                        newBalance.setUser(user);
                        newBalance.setCurrency(currencyEnum);
                        newBalance.setBalanceAmount(amount);
                        newBalance.setCompany(company);
                        balanceRepository.save(newBalance);
                        log.info("✓ Created new balance for user {} with {} {}", userId, amount, currency.getCode());
                    }
                }
                
            } else if (isReactivatingLoan) {
                // ========== REACTIVATING LOAN (ACTIVE/OVERDUE from REPAID/CANCELED) ==========
                log.info("=== UPDATE LOAN STATUS: {} → {} | Reactivating loan ===", oldStatus, newStatus);
                
                // 1. Check user balance first
                Optional<Balance> userBalance = balanceRepository.findByCurrencyAndUserId(currencyEnum, userId);
                BigDecimal availableBalance = userBalance.map(Balance::getBalanceAmount).orElse(BigDecimal.ZERO);
                
                if (availableBalance.compareTo(amount) < 0) {
                    log.warn("✗ Insufficient balance. Available: {} {}, Required: {} {}", 
                            availableBalance, currency.getCode(), amount, currency.getCode());
                    throw new ValidationException(List.of(
                            ErrorMessage.builder()
                                    .status(400)
                                    .messageFr("Solde insuffisant pour réactiver ce crédit. Disponible: " + availableBalance + " " + currency.getCode())
                                    .messageEn("Insufficient balance to reactivate this loan. Available: " + availableBalance + " " + currency.getCode())
                                    .build()));
                }

                // 2. Deduct from user balance
                Balance balance = userBalance.get();
                balance.setBalanceAmount(balance.getBalanceAmount().subtract(amount));
                balanceRepository.save(balance);
                log.info("✓ Deducted {} {} from user {} balance. New: {}", amount, currency.getCode(), userId, balance.getBalanceAmount());

                // 3. Add to client's BalanceLoan
                BalanceLoan clientBalanceLoan = balanceLoanRepository.findByClientAndCurrency(loan.getClient(), loan.getCurrency())
                        .orElse(BalanceLoan.builder()
                                .client(loan.getClient())
                                .currency(loan.getCurrency())
                                .company(company)
                                .balanceAmount(BigDecimal.ZERO)
                                .build());
                clientBalanceLoan.setBalanceAmount(clientBalanceLoan.getBalanceAmount().add(amount));
                balanceLoanRepository.save(clientBalanceLoan);
                log.info("✓ Added {} {} to client '{}' balance_loan. New: {}", 
                        amount, currency.getCode(), loan.getClient().getFullName(), clientBalanceLoan.getBalanceAmount());
            }
        }

        // Update loan fields
        loan.setClient(client);
        loan.setCurrency(currency);
        loan.setAmount(request.getAmount());
        loan.setLoanType(request.getLoanType());
        loan.setLenderName(request.getLenderName());
        loan.setExchangeRate(request.getExchangeRate());
        loan.setIssueDate(request.getIssueDate());
        loan.setDueDate(request.getDueDate());
        loan.setInterestRate(request.getInterestRate() != null ? request.getInterestRate() : BigDecimal.ZERO);
        loan.setCollateral(request.getCollateral());
        loan.setNotes(request.getNotes());
        loan.setIsConfidential(request.getIsConfidential() != null ? request.getIsConfidential() : false);
        loan.setStatus(newStatus);

        loan = loanRepository.save(loan);
        log.info("Loan {} updated successfully. Status: {} → {}", loanId, oldStatus, newStatus);
        return toLoanResponse(loan);
    }

    @Override
    @Transactional
    public void updateLoanStatus(Long loanId, String status, Company company, Long userId) {
        // Fetch loan and validate ownership
        Loan loan = getLoanWithOwnershipCheck(loanId, company, userId);

        LoanStatus oldStatus = loan.getStatus();
        LoanStatus newStatus = LoanStatus.valueOf(status.toUpperCase());
        
        // Skip if status is the same
        if (oldStatus == newStatus) {
            return;
        }

        Currency currency = loan.getCurrency();
        LoanClient client = loan.getClient();
        BigDecimal amount = loan.getAmount().subtract(loan.getPaidAmount()); // Remaining amount

        // Convert currency code to enum for Balance lookup
        com.exchange.currencyexchangebackend.model.enums.Currency currencyEnum;
        try {
            currencyEnum = com.exchange.currencyexchangebackend.model.enums.Currency.valueOf(currency.getCode());
        } catch (IllegalArgumentException e) {
            throw new ValidationException(List.of(
                    ErrorMessage.builder().status(400).messageFr("Devise non supportée").messageEn("Unsupported currency").build()));
        }

        // Handle balance changes based on status transition
        // REPAID/CANCELED: Client returns money → balance_loan decreases, user balance increases
        // ACTIVE/OVERDUE (from REPAID/CANCELED): Loan reactivated → user balance decreases, balance_loan increases
        
        boolean isReturningMoney = (newStatus == LoanStatus.REPAID || newStatus == LoanStatus.CANCELED);
        boolean isReactivatingLoan = ((newStatus == LoanStatus.ACTIVE || newStatus == LoanStatus.OVERDUE) 
                                      && (oldStatus == LoanStatus.REPAID || oldStatus == LoanStatus.CANCELED));

        if (isReturningMoney) {
            // ========== CLIENT RETURNED MONEY (REPAID/CANCELED) ==========
            // Money flow: balance_loan → balance
            log.info("=== STATUS CHANGE: {} → {} | Client returns money ===", oldStatus, newStatus);
            
            // 1. Deduct from client's BalanceLoan
            BalanceLoan clientBalanceLoan = balanceLoanRepository.findByClientAndCurrency(client, currency)
                    .orElse(null);
            if (clientBalanceLoan != null) {
                BigDecimal deductAmount = amount.min(clientBalanceLoan.getBalanceAmount()); // Don't go negative
                clientBalanceLoan.setBalanceAmount(clientBalanceLoan.getBalanceAmount().subtract(deductAmount));
                balanceLoanRepository.save(clientBalanceLoan);
                log.info("✓ Deducted {} {} from client '{}' balance_loan. New balance_loan: {}", 
                        deductAmount, currency.getCode(), client.getFullName(), clientBalanceLoan.getBalanceAmount());
            }

            // 2. Add to user's Balance
            Optional<Balance> userBalance = balanceRepository.findByCurrencyAndUserId(currencyEnum, userId);
            if (userBalance.isPresent()) {
                Balance balance = userBalance.get();
                balance.setBalanceAmount(balance.getBalanceAmount().add(amount));
                balanceRepository.save(balance);
                log.info("✓ Added {} {} to user {} balance. New balance: {}", 
                        amount, currency.getCode(), userId, balance.getBalanceAmount());
            } else {
                // Create new balance if not exists
                User user = userRepository.findById(userId).orElse(null);
                if (user != null) {
                    Balance newBalance = new Balance();
                    newBalance.setUser(user);
                    newBalance.setCurrency(currencyEnum);
                    newBalance.setBalanceAmount(amount);
                    newBalance.setCompany(company);
                    balanceRepository.save(newBalance);
                    log.info("✓ Created new balance for user {} with {} {}", 
                            userId, amount, currency.getCode());
                }
            }
            
        } else if (isReactivatingLoan) {
            // ========== REACTIVATING LOAN (ACTIVE/OVERDUE from REPAID/CANCELED) ==========
            // Money flow: balance → balance_loan
            log.info("=== STATUS CHANGE: {} → {} | Reactivating loan ===", oldStatus, newStatus);
            
            // 1. Check user balance first
            Optional<Balance> userBalance = balanceRepository.findByCurrencyAndUserId(currencyEnum, userId);
            BigDecimal availableBalance = userBalance.map(Balance::getBalanceAmount).orElse(BigDecimal.ZERO);
            
            if (availableBalance.compareTo(amount) < 0) {
                log.warn("✗ Insufficient balance to reactivate loan. Available: {} {}, Required: {} {}", 
                        availableBalance, currency.getCode(), amount, currency.getCode());
                throw new ValidationException(List.of(
                        ErrorMessage.builder()
                                .status(400)
                                .messageFr("Solde insuffisant pour réactiver ce crédit. Disponible: " + availableBalance + " " + currency.getCode())
                                .messageEn("Insufficient balance to reactivate this loan. Available: " + availableBalance + " " + currency.getCode())
                                .build()));
            }

            // 2. Deduct from user balance
            Balance balance = userBalance.get();
            balance.setBalanceAmount(balance.getBalanceAmount().subtract(amount));
            balanceRepository.save(balance);
            log.info("✓ Deducted {} {} from user {} balance. New balance: {}", 
                    amount, currency.getCode(), userId, balance.getBalanceAmount());

            // 3. Add to client's BalanceLoan
            BalanceLoan clientBalanceLoan = balanceLoanRepository.findByClientAndCurrency(client, currency)
                    .orElse(BalanceLoan.builder()
                            .client(client)
                            .currency(currency)
                            .company(company)
                            .balanceAmount(BigDecimal.ZERO)
                            .build());
            clientBalanceLoan.setBalanceAmount(clientBalanceLoan.getBalanceAmount().add(amount));
            balanceLoanRepository.save(clientBalanceLoan);
            log.info("✓ Added {} {} to client '{}' balance_loan. New balance_loan: {}", 
                    amount, currency.getCode(), client.getFullName(), clientBalanceLoan.getBalanceAmount());
        }
        // Note: ACTIVE→OVERDUE or OVERDUE→ACTIVE without balance change (just due date status)

        loan.setStatus(newStatus);
        if (isReturningMoney) {
            loan.setPaidAmount(loan.getAmount());
        } else if (isReactivatingLoan) {
            loan.setPaidAmount(BigDecimal.ZERO);
        }
        loanRepository.save(loan);
        log.info("Loan {} status updated from {} to {}", loanId, oldStatus, newStatus);
    }
    
    @Override
    @Transactional
    public void deleteLoan(Long loanId, Company company, Long userId) {
        // Fetch loan and validate ownership
        Loan loan = getLoanWithOwnershipCheck(loanId, company, userId);

        Currency currency = loan.getCurrency();
        LoanClient client = loan.getClient();
        BigDecimal amount = loan.getAmount().subtract(loan.getPaidAmount()); // Remaining amount to return

        // Only return money if loan is not already REPAID or CANCELED
        if (loan.getStatus() == LoanStatus.ACTIVE || loan.getStatus() == LoanStatus.OVERDUE) {
            // Convert currency code to enum for Balance lookup
            com.exchange.currencyexchangebackend.model.enums.Currency currencyEnum;
            try {
                currencyEnum = com.exchange.currencyexchangebackend.model.enums.Currency.valueOf(currency.getCode());
            } catch (IllegalArgumentException e) {
                log.warn("Could not convert currency {} to enum for balance update", currency.getCode());
                currencyEnum = null;
            }

            if (currencyEnum != null && amount.compareTo(BigDecimal.ZERO) > 0) {
                // Deduct from client's BalanceLoan
                BalanceLoan clientBalanceLoan = balanceLoanRepository.findByClientAndCurrency(client, currency).orElse(null);
                if (clientBalanceLoan != null) {
                    clientBalanceLoan.setBalanceAmount(clientBalanceLoan.getBalanceAmount().subtract(amount));
                    if (clientBalanceLoan.getBalanceAmount().compareTo(BigDecimal.ZERO) < 0) {
                        clientBalanceLoan.setBalanceAmount(BigDecimal.ZERO);
                    }
                    balanceLoanRepository.save(clientBalanceLoan);
                    log.info("Delete loan - Deducted {} {} from client {} balance_loan", 
                            amount, currency.getCode(), client.getFullName());
                }

                // Add to user Balance
                Optional<Balance> userBalance = balanceRepository.findByCurrencyAndUserId(currencyEnum, userId);
                if (userBalance.isPresent()) {
                    Balance balance = userBalance.get();
                    balance.setBalanceAmount(balance.getBalanceAmount().add(amount));
                    balanceRepository.save(balance);
                    log.info("Delete loan - Added {} {} to user {} balance", 
                            amount, currency.getCode(), userId);
                } else {
                    // Create new balance if not exists
                    User user = userRepository.findById(userId).orElse(null);
                    if (user != null) {
                        Balance newBalance = new Balance();
                        newBalance.setUser(user);
                        newBalance.setCurrency(currencyEnum);
                        newBalance.setBalanceAmount(amount);
                        newBalance.setCompany(company);
                        balanceRepository.save(newBalance);
                        log.info("Delete loan - Created new balance for user {} with {} {}", 
                                userId, amount, currency.getCode());
                    }
                }
            }
        }

        loanPaymentRepository.findByLoan(loan).forEach(loanPaymentRepository::delete);
        loanRepository.delete(loan);
        log.info("Loan {} deleted successfully", loanId);
    }
    
