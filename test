    @Override
    public ManagerDashboardDTO getManagerDashboard(Company company) {
        log.info("Getting manager dashboard for company: {}", company.getId());
        
        // Get all loans for the company
        List<Loan> allLoans = loanRepository.findByCompany(company);
        
        // Get all users in the company
        List<User> companyUsers = userRepository.findByCompany(company);
        
        // Get all clients in the company
        List<LoanClient> companyClients = loanClientRepository.findByCompany(company);
        
        // Global statistics
        int totalLoans = allLoans.size();
        int activeLoans = (int) allLoans.stream().filter(l -> l.getStatus() == LoanStatus.ACTIVE).count();
        int overdueLoans = (int) allLoans.stream().filter(l -> l.getStatus() == LoanStatus.OVERDUE).count();
        int repaidLoans = (int) allLoans.stream().filter(l -> l.getStatus() == LoanStatus.REPAID).count();
        
        // Financial metrics (REPAID/CANCELED = fully paid)
        BigDecimal totalCreditAmount = allLoans.stream().map(Loan::getAmount).reduce(BigDecimal.ZERO, BigDecimal::add);
        BigDecimal totalPaidAmount = allLoans.stream()
                .map(l -> (l.getStatus() == LoanStatus.REPAID || l.getStatus() == LoanStatus.CANCELED)
                        ? l.getAmount()
                        : (l.getPaidAmount() != null ? l.getPaidAmount() : BigDecimal.ZERO))
                .reduce(BigDecimal.ZERO, BigDecimal::add);
        BigDecimal totalUnpaidAmount = totalCreditAmount.subtract(totalPaidAmount);
        double paidPercentage = totalCreditAmount.compareTo(BigDecimal.ZERO) == 0 ? 0 : 
                totalPaidAmount.divide(totalCreditAmount, 4, RoundingMode.HALF_UP).doubleValue() * 100;
        
        // Currency breakdown (totalLoaned, totalPaid, totalRemaining per currency)
        Map<String, BigDecimal> loanedByCurrency = new HashMap<>();
        Map<String, BigDecimal> paidByCurrency = new HashMap<>();
        Map<String, BigDecimal> remainingByCurrency = new HashMap<>();
        Map<String, Integer> countByCurrency = new HashMap<>();
        for (Loan l : allLoans) {
            String code = l.getCurrency().getCode();
            BigDecimal amt = l.getAmount();
            BigDecimal paid = (l.getStatus() == LoanStatus.REPAID || l.getStatus() == LoanStatus.CANCELED)
                    ? amt
                    : (l.getPaidAmount() != null ? l.getPaidAmount() : BigDecimal.ZERO);
            BigDecimal remaining = amt.subtract(paid);
            loanedByCurrency.merge(code, amt, BigDecimal::add);
            paidByCurrency.merge(code, paid, BigDecimal::add);
            remainingByCurrency.merge(code, remaining, BigDecimal::add);
            countByCurrency.merge(code, 1, Integer::sum);
        }
        
        List<CurrencyBreakdownDTO> currencyBreakdown = loanedByCurrency.keySet().stream()
                .map(code -> new CurrencyBreakdownDTO(code, remainingByCurrency.get(code), countByCurrency.getOrDefault(code, 0),
                        loanedByCurrency.getOrDefault(code, BigDecimal.ZERO),
                        paidByCurrency.getOrDefault(code, BigDecimal.ZERO),
                        remainingByCurrency.getOrDefault(code, BigDecimal.ZERO)))
                .collect(Collectors.toList());
        
        // Per-user statistics
        List<UserLoanStatsDTO> userStats = companyUsers.stream()
                .map(user -> {
                    List<Loan> userLoans = allLoans.stream()
                            .filter(l -> l.getCreatedBy() != null && l.getCreatedBy().getId().equals(user.getId()))
                            .collect(Collectors.toList());
                    
                    if (userLoans.isEmpty()) {
                        return UserLoanStatsDTO.builder()
                                .userId(user.getId())
                                .fullName(user.getFullName())
                                .email(user.getEmail())
                                .totalLoans(0)
                                .activeLoans(0)
                                .overdueLoans(0)
                                .repaidLoans(0)
                                .totalCreditAmount(BigDecimal.ZERO)
                                .totalPaidAmount(BigDecimal.ZERO)
                                .totalUnpaidAmount(BigDecimal.ZERO)
                                .paymentRate(0)
                                .totalClients(0)
                                .clientsWithOverdue(0)
                                .currencyBreakdown(Collections.emptyList())
                                .build();
                    }
                    
                    BigDecimal userTotalCredit = userLoans.stream().map(Loan::getAmount).reduce(BigDecimal.ZERO, BigDecimal::add);
                    BigDecimal userTotalPaid = userLoans.stream()
                            .map(l -> (l.getStatus() == LoanStatus.REPAID || l.getStatus() == LoanStatus.CANCELED)
                                    ? l.getAmount()
                                    : (l.getPaidAmount() != null ? l.getPaidAmount() : BigDecimal.ZERO))
                            .reduce(BigDecimal.ZERO, BigDecimal::add);
                    BigDecimal userTotalUnpaid = userTotalCredit.subtract(userTotalPaid);
                    double userPaymentRate = userTotalCredit.compareTo(BigDecimal.ZERO) == 0 ? 0 :
                            userTotalPaid.divide(userTotalCredit, 4, RoundingMode.HALF_UP).doubleValue() * 100;
                    
                    Set<Long> userClients = userLoans.stream().map(l -> l.getClient().getId()).collect(Collectors.toSet());
                    Set<Long> clientsWithOverdue = userLoans.stream()
                            .filter(l -> l.getStatus() == LoanStatus.OVERDUE)
                            .map(l -> l.getClient().getId())
                            .collect(Collectors.toSet());

                    // Per-user currency breakdown
                    Map<String, BigDecimal> uLoaned = new HashMap<>();
                    Map<String, BigDecimal> uPaid = new HashMap<>();
                    Map<String, BigDecimal> uRemaining = new HashMap<>();
                    Map<String, Integer> uCount = new HashMap<>();
                    for (Loan l : userLoans) {
                        String code = l.getCurrency().getCode();
                        BigDecimal amt = l.getAmount();
                        BigDecimal paid = (l.getStatus() == LoanStatus.REPAID || l.getStatus() == LoanStatus.CANCELED)
                                ? amt
                                : (l.getPaidAmount() != null ? l.getPaidAmount() : BigDecimal.ZERO);
                        BigDecimal rem = amt.subtract(paid);
                        uLoaned.merge(code, amt, BigDecimal::add);
                        uPaid.merge(code, paid, BigDecimal::add);
                        uRemaining.merge(code, rem, BigDecimal::add);
                        uCount.merge(code, 1, Integer::sum);
                    }
                    List<CurrencyBreakdownDTO> userCurrencyBreakdown = uLoaned.keySet().stream()
                            .map(code -> new CurrencyBreakdownDTO(code, uRemaining.get(code), uCount.getOrDefault(code, 0),
                                    uLoaned.getOrDefault(code, BigDecimal.ZERO),
                                    uPaid.getOrDefault(code, BigDecimal.ZERO),
                                    uRemaining.getOrDefault(code, BigDecimal.ZERO)))
                            .collect(Collectors.toList());
                    
                    return UserLoanStatsDTO.builder()
                            .userId(user.getId())
                            .fullName(user.getFullName())
                            .email(user.getEmail())
                            .totalLoans(userLoans.size())
                            .activeLoans((int) userLoans.stream().filter(l -> l.getStatus() == LoanStatus.ACTIVE).count())
                            .overdueLoans((int) userLoans.stream().filter(l -> l.getStatus() == LoanStatus.OVERDUE).count())
                            .repaidLoans((int) userLoans.stream().filter(l -> l.getStatus() == LoanStatus.REPAID).count())
                            .totalCreditAmount(userTotalCredit)
                            .totalPaidAmount(userTotalPaid)
                            .totalUnpaidAmount(userTotalUnpaid)
                            .paymentRate(Math.round(userPaymentRate * 10) / 10.0)
                            .totalClients(userClients.size())
                            .clientsWithOverdue(clientsWithOverdue.size())
                            .currencyBreakdown(userCurrencyBreakdown)
                            .build();
                })
                .filter(stats -> stats.getTotalLoans() > 0)
                .sorted((a, b) -> Integer.compare(b.getTotalLoans(), a.getTotalLoans()))
                .collect(Collectors.toList());
        
        // Top clients with most debt (aggregated per client)
        Map<Long, List<Loan>> loansByClient = allLoans.stream()
                .filter(l -> l.getStatus() == LoanStatus.ACTIVE || l.getStatus() == LoanStatus.OVERDUE)
                .collect(Collectors.groupingBy(l -> l.getClient().getId()));
        
        List<ClientDebtDTO> topDebtClients = loansByClient.entrySet().stream()
                .map(entry -> {
                    List<Loan> clientLoans = entry.getValue();
                    LoanClient client = clientLoans.get(0).getClient();
                    BigDecimal totalDebt = clientLoans.stream()
                            .map(l -> l.getAmount().subtract(l.getPaidAmount()))
                            .reduce(BigDecimal.ZERO, BigDecimal::add);
                    int overdueCount = (int) clientLoans.stream().filter(l -> l.getStatus() == LoanStatus.OVERDUE).count();
                    
                    String createdByName = clientLoans.get(0).getCreatedBy() != null ? 
                            clientLoans.get(0).getCreatedBy().getFullName() : "N/A";
                    Long createdById = clientLoans.get(0).getCreatedBy() != null ? 
                            clientLoans.get(0).getCreatedBy().getId() : null;
                    
                    return ClientDebtDTO.builder()
                            .clientId(client.getId())
                            .fullName(client.getFullName())
                            .cin(client.getCin())
                            .phoneNumber(client.getPhoneNumber())
                            .totalDebt(totalDebt)
                            .currency(clientLoans.get(0).getCurrency().getCode())
                            .loansCount(clientLoans.size())
                            .overdueCount(overdueCount)
                            .createdByUserName(createdByName)
                            .createdByUserId(createdById)
                            .build();
                })
                .sorted((a, b) -> b.getTotalDebt().compareTo(a.getTotalDebt()))
                .limit(10)
                .collect(Collectors.toList());
        
        // Overdue loans details
        LocalDate today = LocalDate.now();
        List<OverdueLoanDTO> overdueLoansDetails = allLoans.stream()
                .filter(l -> l.getStatus() == LoanStatus.OVERDUE)
                .map(loan -> {
                    int daysOverdue = loan.getDueDate() != null ? 
                            (int) java.time.temporal.ChronoUnit.DAYS.between(loan.getDueDate(), today) : 0;
                    
                    return OverdueLoanDTO.builder()
                            .loanId(loan.getId())
                            .clientId(loan.getClient().getId())
                            .clientName(loan.getClient().getFullName())
                            .clientCin(loan.getClient().getCin())
                            .clientPhone(loan.getClient().getPhoneNumber())
                            .amount(loan.getAmount())
                            .paidAmount(loan.getPaidAmount())
                            .remainingAmount(loan.getAmount().subtract(loan.getPaidAmount()))
                            .currency(loan.getCurrency().getCode())
                            .issueDate(loan.getIssueDate())
                            .dueDate(loan.getDueDate())
                            .daysOverdue(daysOverdue)
                            .createdByUserId(loan.getCreatedBy() != null ? loan.getCreatedBy().getId() : null)
                            .createdByUserName(loan.getCreatedBy() != null ? loan.getCreatedBy().getFullName() : "N/A")
                            .build();
                })
                .sorted((a, b) -> Integer.compare(b.getDaysOverdue(), a.getDaysOverdue()))
                .collect(Collectors.toList());
        
        return ManagerDashboardDTO.builder()
                .totalUsers(companyUsers.size())
                .totalClients(companyClients.size())
                .totalLoans(totalLoans)
                .activeLoans(activeLoans)
                .overdueLoans(overdueLoans)
                .repaidLoans(repaidLoans)
                .totalCreditAmount(totalCreditAmount)
                .totalPaidAmount(totalPaidAmount)
                .totalUnpaidAmount(totalUnpaidAmount)
                .paidPercentage(Math.round(paidPercentage * 10) / 10.0)
                .currencyBreakdown(currencyBreakdown)
                .userStats(userStats)
                .topDebtClients(topDebtClients)
                .overdueLoansDetails(overdueLoansDetails)
                .build();
    }

    private LoanStatus resolveStatus(LocalDate issueDate, LocalDate dueDate, String statusStr) {
        if (statusStr != null && !statusStr.isBlank()) {
            try {
                return LoanStatus.valueOf(statusStr.toUpperCase());
            } catch (IllegalArgumentException ignored) {}
        }
        // If no dueDate provided, default to ACTIVE
        if (dueDate == null) {
            return LoanStatus.ACTIVE;
        }
        LocalDate today = LocalDate.now();
        if (dueDate.isBefore(today)) return LoanStatus.OVERDUE;
        return LoanStatus.ACTIVE;
    }

    private LocalDate parseDate(String s) {
        if (s == null || s.isBlank()) return null;
        try {
            return LocalDate.parse(s);
        } catch (Exception e) {
            return null;
        }
    }

    private LoanResponse toLoanResponse(Loan loan) {
        return LoanResponse.builder()
                .id(loan.getId())
                .userId(loan.getClient().getId())
                .customerName(loan.getClient().getFullName())
                .cin(loan.getClient().getCin())
                .email(loan.getClient().getEmail())
                .phoneNumber(loan.getClient().getPhoneNumber())
                .currencyId(loan.getCurrency().getId())
                .currency(loan.getCurrency().getCode())
                .currencyName(loan.getCurrency().getName())
                .currencyFlag(loan.getCurrency().getFlagUrl())
                .amount(loan.getAmount())
                .paidAmount(loan.getPaidAmount())
                .loanType(loan.getLoanType() != null ? loan.getLoanType().name() : null)
                .lenderName(loan.getLenderName())
                .exchangeRate(loan.getExchangeRate())
                .issueDate(loan.getIssueDate())
                .dueDate(loan.getDueDate())
                .status(loan.getStatus().name())
                .interestRate(loan.getInterestRate())
                .collateral(loan.getCollateral())
                .notes(loan.getNotes())
                .isConfidential(loan.getIsConfidential())
                .createdAt(loan.getCreatedAt() != null ? loan.getCreatedAt().toInstant().atZone(ZoneId.systemDefault()).toLocalDateTime() : null)
                .updatedAt(loan.getUpdatedAt() != null ? loan.getUpdatedAt().toInstant().atZone(ZoneId.systemDefault()).toLocalDateTime() : null)
                .build();
    }
}


package com.exchange.currencyexchangebackend.service.impl;

import com.exchange.currencyexchangebackend.exception.ValidationException;
import com.exchange.currencyexchangebackend.model.dto.*;
import com.exchange.currencyexchangebackend.model.entity.Company;
import com.exchange.currencyexchangebackend.model.entity.Loan;
import com.exchange.currencyexchangebackend.model.entity.LoanClient;
import com.exchange.currencyexchangebackend.model.enums.LoanStatus;
import com.exchange.currencyexchangebackend.repository.LoanClientRepository;
import com.exchange.currencyexchangebackend.repository.LoanRepository;
import com.exchange.currencyexchangebackend.service.UserLoanService;
import com.exchange.currencyexchangebackend.util.ErrorMessage;
import lombok.AllArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Pageable;
import org.springframework.stereotype.Service;

import java.time.LocalDateTime;
import java.time.ZoneId;
import java.util.List;
import java.util.stream.Collectors;

@Service
@AllArgsConstructor
@Slf4j
public class UserLoanServiceImpl implements UserLoanService {

    private final LoanClientRepository loanClientRepository;
    private final LoanRepository loanRepository;

    @Override
    public PageResponse<UserLoanResponse> getAllUsers(int page, int size, String search) {
        throw new UnsupportedOperationException("Use LoanController with company context");
    }

    public PageResponse<UserLoanResponse> getAllClients(Company company, int page, int size, String search) {
        log.debug("Fetching clients - Company: {} | Page: {} | Size: {} | Search: {}", company.getId(), page, size, search);
        
        Pageable pageable = PageRequest.of(page, size);
        Page<LoanClient> clientPage = (search == null || search.isBlank())
                ? loanClientRepository.findByCompany(company, pageable)
                : loanClientRepository.searchByCompany(company, search.trim(), pageable);

        List<UserLoanResponse> content = clientPage.getContent().stream()
                .map(this::toUserLoanResponse)
                .collect(Collectors.toList());

        log.debug("Found {} clients (total: {})", content.size(), clientPage.getTotalElements());
        
        return PageResponse.<UserLoanResponse>builder()
                .content(content)
                .currentPage(clientPage.getNumber())
                .pageSize(clientPage.getSize())
                .totalElements(clientPage.getTotalElements())
                .totalPages(clientPage.getTotalPages())
                .hasNext(clientPage.hasNext())
                .hasPrevious(clientPage.hasPrevious())
                .build();
    }

    @Override
    public UserLoanResponse getUserById(Long id) {
        throw new UnsupportedOperationException("Use getClientById with company context");
    }

    public UserLoanResponse getClientById(Long id, Company company) {
        log.debug("Fetching client by ID: {} | Company: {}", id, company.getId());
        
        LoanClient client = loanClientRepository.findByIdAndCompanyId(id, company.getId())
                .orElseThrow(() -> {
                    log.warn("Client not found - ID: {} | Company: {}", id, company.getId());
                    return new ValidationException(List.of(
                        ErrorMessage.builder().status(404).messageFr("Client non trouvé").messageEn("Client not found").build()));
                });
        return toUserLoanResponse(client);
    }

    @Override
    public UserLoanResponse createUser(UserLoanRequest request) {
        throw new UnsupportedOperationException("Use createClient with company context");
    }

    public UserLoanResponse createClient(UserLoanRequest request, Company company) {
        log.info("Creating client - Name: {} | CIN: {} | Company: {}", request.getFullName(), request.getCin(), company.getId());
        
        if (loanClientRepository.existsByCinAndCompany(request.getCin(), company)) {
            log.warn("Client creation failed - CIN already exists: {} | Company: {}", request.getCin(), company.getId());
            throw new ValidationException(List.of(
                    ErrorMessage.builder().status(400).messageFr("Un client avec ce CIN existe déjà").messageEn("Client with this CIN already exists").build()));
        }
        
        LoanClient client = LoanClient.builder()
                .fullName(request.getFullName())
                .cin(request.getCin())
                .email(request.getEmail())
                .phoneNumber(request.getPhoneNumber())
                .address(request.getAddress())
                .company(company)
                .build();
        client = loanClientRepository.save(client);
        log.info("Client created successfully - ID: {} | Name: {}", client.getId(), client.getFullName());
        return toUserLoanResponse(client);
    }

    @Override
    public UserLoanResponse updateUser(Long id, UserLoanRequest request) {
        throw new UnsupportedOperationException("Use updateClient with company context");
    }

    public UserLoanResponse updateClient(Long id, UserLoanRequest request, Company company) {
        log.info("Updating client - ID: {} | Company: {}", id, company.getId());
        
        LoanClient client = loanClientRepository.findByIdAndCompanyId(id, company.getId())
                .orElseThrow(() -> {
                    log.warn("Client update failed - Client not found: {} | Company: {}", id, company.getId());
                    return new ValidationException(List.of(
                        ErrorMessage.builder().status(404).messageFr("Client non trouvé").messageEn("Client not found").build()));
                });

        if (loanClientRepository.existsByCinAndCompanyAndIdNot(request.getCin(), company, id)) {
            log.warn("Client update failed - CIN already used by another client: {}", request.getCin());
            throw new ValidationException(List.of(
                    ErrorMessage.builder().status(400).messageFr("Un autre client utilise ce CIN").messageEn("Another client uses this CIN").build()));
        }

        client.setFullName(request.getFullName());
        client.setCin(request.getCin());
        client.setEmail(request.getEmail());
        client.setPhoneNumber(request.getPhoneNumber());
        client.setAddress(request.getAddress());
        client = loanClientRepository.save(client);
        log.info("Client updated successfully - ID: {} | Name: {}", client.getId(), client.getFullName());
        return toUserLoanResponse(client);
    }

    @Override
    public void deleteUser(Long id) {
        throw new UnsupportedOperationException("Use deleteClient with company context");
    }

    public void deleteClient(Long id, Company company) {
        log.info("Deleting client - ID: {} | Company: {}", id, company.getId());
        
        LoanClient client = loanClientRepository.findByIdAndCompanyId(id, company.getId())
                .orElseThrow(() -> {
                    log.warn("Client deletion failed - Client not found: {} | Company: {}", id, company.getId());
                    return new ValidationException(List.of(
                        ErrorMessage.builder().status(404).messageFr("Client non trouvé").messageEn("Client not found").build()));
                });

        List<Loan> loans = loanRepository.findByCompanyAndClientId(company, id);
        if (!loans.isEmpty()) {
            log.warn("Client deletion failed - Client has {} active loans: {}", loans.size(), id);
            throw new ValidationException(List.of(
                    ErrorMessage.builder().status(400).messageFr("Impossible de supprimer : ce client a des crédits actifs").messageEn("Cannot delete: client has active loans").build()));
        }
        
        loanClientRepository.delete(client);
        log.info("Client deleted successfully - ID: {} | Name: {}", id, client.getFullName());
    }

    @Override
    public List<LoanResponse> getUserLoans(Long userId) {
        throw new UnsupportedOperationException("Use getClientLoans with company context");
    }

    public List<LoanResponse> getClientLoans(Long clientId, Company company) {
        log.debug("Fetching loans for client: {} | Company: {}", clientId, company.getId());
        
        List<LoanResponse> loans = loanRepository.findByCompanyAndClientId(company, clientId).stream()
                .map(this::toLoanResponse)
                .collect(Collectors.toList());
        
        log.debug("Found {} loans for client: {}", loans.size(), clientId);
        return loans;
    }

    private UserLoanResponse toUserLoanResponse(LoanClient client) {
        List<Loan> loans = loanRepository.findByClient(client);
        int activeCount = (int) loans.stream().filter(l -> l.getStatus() == LoanStatus.ACTIVE).count();
        int overdueCount = (int) loans.stream().filter(l -> l.getStatus() == LoanStatus.OVERDUE).count();

        return UserLoanResponse.builder()
                .id(client.getId())
                .fullName(client.getFullName())
                .cin(client.getCin())
                .email(client.getEmail())
                .phoneNumber(client.getPhoneNumber())
                .address(client.getAddress())
                .activeLoansCount(activeCount)
                .overdueLoansCount(overdueCount)
                .totalLoans(loans.size())
                .createdAt(toLocalDateTime(client.getCreatedAt()))
                .updatedAt(toLocalDateTime(client.getUpdatedAt()))
                .build();
    }

    private LoanResponse toLoanResponse(Loan loan) {
        return LoanResponse.builder()
                .id(loan.getId())
                .userId(loan.getClient().getId())
                .customerName(loan.getClient().getFullName())
                .cin(loan.getClient().getCin())
                .email(loan.getClient().getEmail())
                .phoneNumber(loan.getClient().getPhoneNumber())
                .currencyId(loan.getCurrency().getId())
                .currency(loan.getCurrency().getCode())
                .currencyName(loan.getCurrency().getName())
                .currencyFlag(loan.getCurrency().getFlagUrl())
                .amount(loan.getAmount())
                .paidAmount(loan.getPaidAmount())
                .loanType(loan.getLoanType() != null ? loan.getLoanType().name() : null)
                .lenderName(loan.getLenderName())
                .exchangeRate(loan.getExchangeRate())
                .issueDate(loan.getIssueDate())
                .dueDate(loan.getDueDate())
                .status(loan.getStatus().name())
                .interestRate(loan.getInterestRate())
                .collateral(loan.getCollateral())
                .notes(loan.getNotes())
                .isConfidential(loan.getIsConfidential())
                .createdAt(toLocalDateTime(loan.getCreatedAt()))
                .updatedAt(toLocalDateTime(loan.getUpdatedAt()))
                .build();
    }

    private static LocalDateTime toLocalDateTime(java.util.Date date) {
        if (date == null) return null;
        return date.toInstant().atZone(ZoneId.systemDefault()).toLocalDateTime();
    }
}

