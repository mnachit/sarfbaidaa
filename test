                        </button>
                        <span class="pagination-text">{{ overduePage }} / {{ totalOverduePages }}</span>
                        <button class="btn btn-sm btn-outline-secondary" (click)="setOverduePage(overduePage + 1)" [disabled]="overduePage === totalOverduePages">
                            <i class="fas fa-chevron-right"></i>
