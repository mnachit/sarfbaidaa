<!-- Loading Overlay -->
<app-loading-spinner [visible]="loading" [message]="'credit.loading' | translate"></app-loading-spinner>

<div class="dashboard-container">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="fas fa-chart-pie"></i>
            </div>
            <div class="header-text">
                <h1>{{ 'credit.dashboard-title' | translate }}</h1>
                <p>{{ 'credit.dashboard-subtitle' | translate }}</p>
            </div>
        </div>
        <div class="header-actions">
            <button class="btn-header btn-header-secondary" (click)="exportToExcel()">
                <i class="fas fa-file-excel"></i>
                Excel
            </button>
            <button class="btn-header btn-header-secondary" (click)="exportToPDF()">
                <i class="fas fa-file-pdf"></i>
                PDF
            </button>
            <button class="btn-header" (click)="refreshDashboard()" [disabled]="loading">
                <i class="fas fa-sync-alt" [class.fa-spin]="loading"></i>
                {{ 'credit.refresh' | translate }}
            </button>
        </div>
    </div>

    <!-- Quick Stats Row -->
    <div class="stats-row">
        <div class="stat-card stat-primary">
            <div class="stat-icon">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ stats?.totalUsers || 0 }}</div>
                <div class="stat-label">{{ 'credit.total-clients' | translate }}</div>
            </div>
        </div>

        <div class="stat-card stat-success">
            <div class="stat-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ stats?.totalActiveLoans || 0 }}</div>
                <div class="stat-label">{{ 'credit.active-credits' | translate }}</div>
            </div>
        </div>

        <div class="stat-card stat-warning">
            <div class="stat-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ stats?.totalOverdueLoans || 0 }}</div>
                <div class="stat-label">{{ 'credit.overdue' | translate }}</div>
            </div>
        </div>

        <div class="stat-card stat-info">
            <div class="stat-icon">
                <i class="fas fa-percentage"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ averagePaymentRate }}%</div>
                <div class="stat-label">{{ 'credit.payment-rate' | translate }}</div>
            </div>
        </div>

        <div class="stat-card stat-danger">
            <div class="stat-icon">
                <i class="fas fa-user-times"></i>
            </div>
            <div class="stat-content">
                <div class="stat-value">{{ totalClientsWithOverdue }}</div>
                <div class="stat-label">{{ 'credit.clients-overdue' | translate }}</div>
            </div>
        </div>
    </div>

    <!-- Currency Breakdown: Table ↗/↙/net (like Excel) -->
    <div class="currency-section" *ngIf="currencyMetrics.length > 0">
        <h2 class="section-title">
            <i class="fas fa-coins me-2"></i>
            {{ 'credit.breakdown-currency' | translate }}
        </h2>
        <div class="table-responsive">
            <table class="table table-currency-direction mb-0">
                <thead>
                    <tr>
                        <th>{{ 'credit.currency' | translate }}</th>
                        <th class="text-end"><span class="text-success">↗</span> {{ 'credit.owed-by-clients' | translate }}</th>
                        <th class="text-end"><span class="text-warning">↙</span> {{ 'credit.you-owe-them' | translate }}</th>
                        <th class="text-end">{{ 'credit.net-balance' | translate }}</th>
                    </tr>
                </thead>
                <tbody>
                    <tr *ngFor="let m of currencyMetrics">
                        <td><i [class]="getCurrencyIcon(m.currency)" class="me-1"></i>{{ m.currency }}</td>
                        <td class="text-end">{{ (m.totalOwedByClients ?? 0) | number:'1.2-2' }}</td>
                        <td class="text-end">{{ (m.totalOwedByBureau ?? 0) | number:'1.2-2' }}</td>
                        <td class="text-end" [class.text-danger]="(m.netAmount ?? 0) < 0" [class.text-success]="(m.netAmount ?? 0) > 0" [class.fw-bold]="true">
                            {{ (m.netAmount ?? 0) | number:'1.2-2' }}
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <!-- Legacy summary row (prêté / payé) -->
        <div class="currency-cards-row mt-3" *ngIf="currencyMetrics.length > 0">
            <div class="currency-card small" *ngFor="let metric of currencyMetrics">
                <div class="currency-subtext">{{ metric.totalLoaned | number:'1.2-2' }} {{ 'credit.loaned' | translate }} · {{ metric.percentagePaid }}% {{ 'credit.paid-percent' | translate }}</div>
            </div>
        </div>
    </div>

    <!-- Filter Card -->
    <div class="card filter-card">
        <div class="card-body">
            <div class="filter-grid">
                <!-- Search Box -->
                <div class="filter-item filter-search">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" class="form-control" 
                               [placeholder]="'credit.search-placeholder' | translate"
                               [(ngModel)]="searchTerm" 
                               (keyup.enter)="onSearch()" />
                    </div>
                </div>

                <!-- Currency Filter -->
                <div class="filter-item">
                    <select class="form-select" [(ngModel)]="selectedCurrency" (change)="onCurrencyFilter(selectedCurrency)">
                        <option value="all">{{ 'credit.all-currencies' | translate }}</option>
                        <option *ngFor="let currency of currencies" [value]="currency">
                            {{ currency }}
                        </option>
                    </select>
                </div>

                <!-- Status Filter -->
                <div class="filter-item">
                    <select class="form-select" [(ngModel)]="selectedStatus" (change)="onStatusFilter(selectedStatus)">
                        <option value="all">{{ 'credit.all-statuses' | translate }}</option>
                        <option value="active">{{ 'credit.with-active' | translate }}</option>
                        <option value="overdue">{{ 'credit.with-overdue' | translate }}</option>
                        <option value="clean">{{ 'credit.without-credit' | translate }}</option>
                    </select>
                </div>

                <!-- Sort By -->
                <div class="filter-item">
                    <select class="form-select" [(ngModel)]="sortBy" (change)="applyFilters()">
                        <option value="name">{{ 'credit.sort-name' | translate }}</option>
                        <option value="balance">{{ 'credit.sort-balance' | translate }}</option>
                        <option value="active">{{ 'credit.sort-active' | translate }}</option>
                        <option value="overdue">{{ 'credit.sort-overdue' | translate }}</option>
                    </select>
                </div>

                <!-- Actions -->
                <div class="filter-item">
                    <button class="btn btn-primary btn-block" (click)="onSearch()">
                        <i class="fas fa-search"></i>
                        {{ 'credit.search-btn' | translate }}
                    </button>
                </div>
            </div>

            <!-- Reset Filters -->
            <div class="active-filters" *ngIf="hasActiveFilters()">
                <span class="filter-label">
                    <i class="fas fa-filter"></i>
                    {{ 'credit.active-filters' | translate }}:
                </span>
                <span class="filter-tag" *ngIf="searchTerm">
                    {{ 'credit.search' | translate }}: "{{ searchTerm }}"
                    <i class="fas fa-times" (click)="searchTerm = ''; loadDashboardData()"></i>
                </span>
                <span class="filter-tag" *ngIf="selectedCurrency !== 'all'">
                    {{ 'credit.currency' | translate }}: {{ selectedCurrency }}
                    <i class="fas fa-times" (click)="selectedCurrency = 'all'; loadDashboardData()"></i>
                </span>
                <span class="filter-tag" *ngIf="selectedStatus !== 'all'">
                    {{ 'credit.status' | translate }}: {{ selectedStatus }}
                    <i class="fas fa-times" (click)="selectedStatus = 'all'; loadDashboardData()"></i>
                </span>
                <button class="btn btn-link btn-sm" (click)="clearFilters()">
                    <i class="fas fa-undo"></i>
                    {{ 'credit.reset-all' | translate }}
                </button>
            </div>
        </div>
    </div>

    <!-- Results Info -->
    <div class="results-info">
        <span class="results-count">
            <strong>{{ filteredUsers.length }}</strong> {{ 'credit.results' | translate }}
            <span *ngIf="filteredUsers.length !== users.length">
                {{ 'credit.results-total' | translate }} {{ users.length }}
            </span>
        </span>
    </div>

    <!-- Table Card -->
    <div class="card table-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table clients-table mb-0">
                    <thead>
                        <tr>
                            <th class="sortable" (click)="onSort('name')">
                                {{ 'credit.table-client' | translate }}
                                <i class="fas fa-sort ms-1" 
                                   [class.fa-sort-up]="sortBy === 'name' && sortOrder === 'asc'"
                                   [class.fa-sort-down]="sortBy === 'name' && sortOrder === 'desc'"></i>
                            </th>
                            <th>{{ 'credit.table-cin' | translate }}</th>
                            <th>{{ 'credit.table-contact' | translate }}</th>
                            <th class="sortable" (click)="onSort('balance')">
                                {{ 'credit.table-balances' | translate }}
                                <i class="fas fa-sort ms-1"></i>
                            </th>
                            <th class="text-center sortable" (click)="onSort('active')">
                                {{ 'credit.table-active' | translate }}
                                <i class="fas fa-sort ms-1"></i>
                            </th>
                            <th class="text-center sortable" (click)="onSort('overdue')">
                                {{ 'credit.table-overdue' | translate }}
                                <i class="fas fa-sort ms-1"></i>
                            </th>
                            <th class="text-center">{{ 'credit.table-actions' | translate }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr *ngFor="let user of getPaginatedUsers()" 
                            [class.row-overdue]="user.overdueLoanCount > 0"
                            [class.row-active]="user.overdueLoanCount === 0 && user.activeLoanCount > 0">
                            
                            <!-- Client -->
                            <td>
                                <div class="customer-cell">
                                    <div class="customer-avatar">
                                        {{ getInitials(user.fullName) }}
                                    </div>
                                    <div class="customer-info">
                                        <span class="customer-name">{{ user.fullName }}</span>
                                        <span class="customer-id">#{{ user.userId }}</span>
                                    </div>
                                </div>
                            </td>

                            <!-- CIN -->
                            <td>
                                <span class="cin-badge">{{ user.cin }}</span>
                            </td>

                            <!-- Contact -->
                            <td>
                                <div class="contact-info">
                                    <div class="contact-item">
                                        <i class="fas fa-envelope"></i>
                                        <a [href]="'mailto:' + user.email">{{ user.email }}</a>
                                    </div>
                                    <div class="contact-item">
                                        <i class="fas fa-phone"></i>
                                        <a [href]="'tel:' + user.phoneNumber">{{ user.phoneNumber }}</a>
                                    </div>
                                </div>
                            </td>

                            <!-- Balances -->
                            <td>
                                <div class="balances-list" *ngIf="getCurrencyKeys(user.balancesByCurrency).length > 0">
                                    <div class="balance-item" *ngFor="let currency of getCurrencyKeys(user.balancesByCurrency)">
                                        <span class="balance-currency">{{ currency }}:</span>
                                        <span class="balance-amount">{{ user.balancesByCurrency[currency] | number:'1.2-2' }}</span>
                                    </div>
                                </div>
                                <span class="no-balance" *ngIf="getCurrencyKeys(user.balancesByCurrency).length === 0">
                                    <i class="fas fa-minus-circle"></i>
                                    {{ 'credit.no-balance' | translate }}
                                </span>
                            </td>

                            <!-- Active Loans -->
                            <td class="text-center">
                                <span class="count-badge badge-success">
                                    <i class="fas fa-check-circle me-1"></i>
                                    {{ user.activeLoanCount }}
                                </span>
                            </td>

                            <!-- Overdue Loans -->
                            <td class="text-center">
                                <span class="count-badge" 
                                      [class.badge-danger]="user.overdueLoanCount > 0"
                                      [class.badge-muted]="user.overdueLoanCount === 0">
                                    <i class="fas me-1" 
                                       [class.fa-exclamation-triangle]="user.overdueLoanCount > 0"
                                       [class.fa-check]="user.overdueLoanCount === 0"></i>
                                    {{ user.overdueLoanCount }}
                                </span>
                            </td>

                            <!-- Actions -->
                            <td class="text-center">
                                <div class="action-buttons">
                                    <button class="btn-action btn-view" 
                                            (click)="viewUserDetails(user)" 
                                            [title]="'credit.view-details' | translate">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                    <button class="btn-action btn-download" 
                                            (click)="exportUserToPDF(user)" 
                                            [title]="'credit.download-sheet' | translate">
                                        <i class="fas fa-file-pdf"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>

                        <!-- Empty State -->
                        <tr *ngIf="filteredUsers.length === 0 && !loading">
                            <td colspan="7" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="fas fa-search fa-3x text-muted mb-3"></i>
                                    <h5>{{ 'credit.no-client-found' | translate }}</h5>
                                    <p class="text-muted">{{ 'credit.no-results' | translate }}</p>
                                    <button class="btn btn-outline-primary" (click)="clearFilters()">
                                        <i class="fas fa-undo me-2"></i>
                                        {{ 'credit.reset-filters-btn' | translate }}
                                    </button>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    <div class="pagination-container" *ngIf="totalPages > 1">
        <div class="pagination-info">
            <select class="form-select form-select-sm page-size-select" [(ngModel)]="pageSize" (change)="updatePagination()">
                <option [value]="10">10</option>
                <option [value]="25">25</option>
                <option [value]="50">50</option>
                <option [value]="100">100</option>
            </select>
            <span class="ms-2">{{ 'credit.per-page' | translate }}</span>
        </div>

        <div class="pagination-controls">
            <button class="btn btn-outline-secondary btn-sm" 
                    (click)="goToPage(1)" 
                    [disabled]="currentPage === 1">
                <i class="fas fa-angle-double-left"></i>
            </button>
            <button class="btn btn-outline-secondary btn-sm" 
                    (click)="previousPage()" 
                    [disabled]="currentPage === 1">
                <i class="fas fa-angle-left"></i>
            </button>
            
            <span class="pagination-text">
                {{ 'credit.page' | translate }} {{ currentPage }} / {{ totalPages }}
            </span>
            
            <button class="btn btn-outline-secondary btn-sm" 
                    (click)="nextPage()" 
                    [disabled]="currentPage === totalPages">
                <i class="fas fa-angle-right"></i>
            </button>
            <button class="btn btn-outline-secondary btn-sm" 
                    (click)="goToPage(totalPages)" 
                    [disabled]="currentPage === totalPages">
                <i class="fas fa-angle-double-right"></i>
            </button>
        </div>

        <div class="pagination-summary">
            {{ 'credit.showing' | translate }}
            <strong>{{ filteredUsers.length > 0 ? (currentPage - 1) * pageSize + 1 : 0 }}</strong>
            {{ 'credit.to' | translate }}
            <strong>{{ Math.min(currentPage * pageSize, filteredUsers.length) }}</strong>
            {{ 'credit.on' | translate }}
            <strong>{{ filteredUsers.length }}</strong>
        </div>
    </div>
</div>

<!-- User Details Modal -->
<div class="modal-overlay" *ngIf="modalOpen && selectedUser" (click)="closeModal()">
    <div class="modal-container" (click)="$event.stopPropagation()">
        <div class="modal-header">
            <div class="modal-header-content">
                <div class="modal-avatar">
                    {{ getInitials(selectedUser.fullName) }}
                </div>
                <div class="modal-user-info">
                    <h2 class="modal-title">{{ selectedUser.fullName }}</h2>
                    <div class="modal-subtitle">
                        <span><i class="fas fa-id-card me-1"></i>{{ selectedUser.cin }}</span>
                        <span class="mx-2">•</span>
                        <span><i class="fas fa-envelope me-1"></i>{{ selectedUser.email }}</span>
                    </div>
                </div>
            </div>
            <button class="modal-close-btn" (click)="closeModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="modal-body">
            <!-- Contact Section -->
            <div class="modal-section">
                <h4 class="section-title">
                    <i class="fas fa-address-card me-2"></i>
                    {{ 'credit.contact-info' | translate }}
                </h4>
                <div class="info-grid">
                    <div class="info-item">
                        <i class="fas fa-phone"></i>
                        <div>
                            <span class="info-label">{{ 'credit.phone' | translate }}</span>
                            <a [href]="'tel:' + selectedUser.phoneNumber" class="info-value">
                                {{ selectedUser.phoneNumber }}
                            </a>
                        </div>
                    </div>
                    <div class="info-item">
                        <i class="fas fa-envelope"></i>
                        <div>
                            <span class="info-label">{{ 'credit.email' | translate }}</span>
                            <a [href]="'mailto:' + selectedUser.email" class="info-value">
                                {{ selectedUser.email }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Stats Section -->
            <div class="modal-section">
                <h4 class="section-title">
                    <i class="fas fa-chart-bar me-2"></i>
                    {{ 'credit.credit-stats' | translate }}
                </h4>
                <div class="modal-stats-row">
                    <div class="modal-stat success">
                        <div class="modal-stat-value">{{ selectedUser.activeLoanCount }}</div>
                        <div class="modal-stat-label">{{ 'credit.active-credits-modal' | translate }}</div>
                    </div>
                    <div class="modal-stat danger">
                        <div class="modal-stat-value">{{ selectedUser.overdueLoanCount }}</div>
                        <div class="modal-stat-label">{{ 'credit.overdue-modal' | translate }}</div>
                    </div>
                    <div class="modal-stat info">
                        <div class="modal-stat-value">{{ selectedUser.activeLoanCount + selectedUser.overdueLoanCount }}</div>
                        <div class="modal-stat-label">{{ 'credit.total-credits' | translate }}</div>
                    </div>
                </div>
            </div>

            <!-- Balances Section (↗/↙/net like Excel) -->
            <div class="modal-section">
                <h4 class="section-title">
                    <i class="fas fa-wallet me-2"></i>
                    {{ 'credit.balances-currency' | translate }}
                </h4>
                <div class="modal-balances-direction" *ngIf="getClientBalanceCurrencies().length > 0">
                    <!-- ↗ Ce qu'il vous doit -->
                    <div class="balance-block balance-owed-by-client">
                        <div class="balance-block-title text-success">
                            <span class="me-1">↗</span> {{ 'credit.owed-by-client' | translate }}
                        </div>
                        <div class="balance-block-amounts">
                            <span *ngFor="let curr of getClientBalanceCurrencies()" class="balance-line d-block">
                                {{ curr }}: {{ formatCurrency((selectedUser.owedByClient || {})[curr] ?? 0, curr) }}
                            </span>
                        </div>
                    </div>
                    <!-- ↙ Ce que vous lui devez -->
                    <div class="balance-block balance-owed-by-bureau">
                        <div class="balance-block-title text-warning">
                            <span class="me-1">↙</span> {{ 'credit.owed-by-bureau' | translate }}
                        </div>
                        <div class="balance-block-amounts">
                            <span *ngFor="let curr of getClientBalanceCurrencies()" class="balance-line d-block">
                                {{ curr }}: {{ formatCurrency((selectedUser.owedByBureau || {})[curr] ?? 0, curr) }}
                            </span>
                        </div>
                    </div>
                    <!-- = Solde net -->
                    <div class="balance-block balance-net">
                        <div class="balance-block-title">
                            <span class="me-1">=</span> {{ 'credit.net-balance' | translate }}
                        </div>
                        <div class="balance-block-amounts">
                            <span *ngFor="let curr of getClientBalanceCurrencies()" class="balance-line d-block" [class.text-danger]="getClientNetAmount(curr) < 0" [class.text-success]="getClientNetAmount(curr) > 0">
                                {{ curr }}: {{ formatCurrency(getClientNetAmount(curr), curr) }}
                                <small *ngIf="getClientNetAmount(curr) > 0" class="ms-1">({{ 'credit.he-owes-you' | translate }})</small>
                                <small *ngIf="getClientNetAmount(curr) < 0" class="ms-1">({{ 'credit.you-owe-him' | translate }})</small>
                            </span>
                        </div>
                    </div>
                </div>
                <div class="no-balances" *ngIf="getClientBalanceCurrencies().length === 0">
                    <i class="fas fa-info-circle"></i>
                    <p>{{ 'credit.no-balance-client' | translate }}</p>
                </div>
            </div>

            <!-- Loans List Section -->
            <div class="modal-section" *ngIf="selectedUserLoans.length > 0">
                <h4 class="section-title">
                    <i class="fas fa-list me-2"></i>
                    {{ 'credit.credits-list' | translate }}
                </h4>
                <div class="loans-search-pagination mb-3">
                    <input type="text" class="form-control form-control-sm" 
                           [(ngModel)]="loansSearchTerm" 
                           (input)="onLoansSearch()"
                           [placeholder]="'credit.search-loans' | translate"
                           style="max-width: 220px;">
                    <span class="loans-pagination-info ms-2 text-muted small">
                        <ng-container *ngIf="getFilteredLoans().length > 0">
                            {{ 'credit.showing' | translate }} {{ (loansCurrentPage - 1) * loansPageSize + 1 }}-{{ Math.min(loansCurrentPage * loansPageSize, getFilteredLoans().length) }} {{ 'credit.on' | translate }} {{ getFilteredLoans().length }}
                        </ng-container>
                        <ng-container *ngIf="getFilteredLoans().length === 0">{{ 'credit.no-results' | translate }}</ng-container>
                    </span>
                </div>
                <div class="loans-list">
                    <div class="loan-item" *ngFor="let loan of getPaginatedLoans()">
                        <div class="loan-header">
                            <span [class]="'status-badge status-' + loan.status.toLowerCase()">
                                {{ loan.status }}
                            </span>
                            <span class="loan-id">#{{ loan.id }}</span>
                            <span [class]="loan.direction === 'CLIENT_TO_BUREAU' ? 'text-warning' : 'text-success'" [title]="(loan.direction === 'CLIENT_TO_BUREAU' ? ('loan.direction-client-to-bureau' | translate) : ('loan.direction-bureau-to-client' | translate))" class="me-1">{{ loan.direction === 'CLIENT_TO_BUREAU' ? '↙' : '↗' }}</span>
                            <span *ngIf="loan.loanType" class="badge badge-info ms-1">{{ loan.loanType }}</span>
                            <span *ngIf="loan.lenderName" class="text-muted small ms-1">{{ loan.lenderName }}</span>
                        </div>
                        <div class="loan-details">
                            <div class="loan-detail">
                                <span class="detail-label">{{ 'credit.amount' | translate }}:</span>
                                <span class="detail-value">{{ formatCurrency(loan.amount, loan.currency) }}</span>
                            </div>
                            <div class="loan-detail">
                                <span class="detail-label">{{ 'loan.remaining' | translate }}:</span>
                                <span class="detail-value">{{ formatCurrency(getLoanRemaining(loan), loan.currency) }}</span>
                                <small class="text-muted" *ngIf="(loan.paidAmount ?? 0) > 0">({{ 'loan.paid' | translate }}: {{ formatCurrency(loan.paidAmount ?? 0, loan.currency) }})</small>
                            </div>
                            <div class="loan-detail">
                                <span class="detail-label">{{ 'credit.issue-date' | translate }}:</span>
                                <span class="detail-value">{{ formatDate(loan.issueDate) }}</span>
                            </div>
                            <div class="loan-detail">
                                <span class="detail-label">{{ 'credit.due-date' | translate }}:</span>
                                <span class="detail-value">{{ formatDate(loan.dueDate) }}</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="loans-pagination-controls mt-3" *ngIf="loansTotalPages > 1">
                    <button class="btn btn-sm btn-outline-secondary" [disabled]="loansCurrentPage === 1" (click)="loansPrevPage()">
                        <i class="fas fa-chevron-left"></i>
                    </button>
                    <span class="mx-2 small">{{ 'credit.page' | translate }} {{ loansCurrentPage }} / {{ loansTotalPages }}</span>
                    <button class="btn btn-sm btn-outline-secondary" [disabled]="loansCurrentPage >= loansTotalPages" (click)="loansNextPage()">
                        <i class="fas fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button class="btn btn-outline-secondary" (click)="closeModal()">
                <i class="fas fa-times me-2"></i>
                {{ 'credit.close' | translate }}
            </button>
            <button class="btn btn-success" (click)="openBulkPaymentModal()" *ngIf="getTotalDueForUser() > 0">
                <i class="fas fa-money-bill-wave me-2"></i>
                {{ 'credit.bulk-payment-btn' | translate }}
            </button>
            <button class="btn btn-primary" (click)="exportUserToPDF(selectedUser)">
                <i class="fas fa-download me-2"></i>
                {{ 'credit.download-file' | translate }}
            </button>
        </div>
    </div>
</div>

<!-- Bulk Payment Modal -->
<div class="modal-overlay bulk-payment-overlay" *ngIf="bulkPaymentModalOpen && selectedUser" (click)="closeBulkPaymentModal()">
    <div class="bulk-payment-modal-content" (click)="$event.stopPropagation()">
        <div class="modal-header bg-success text-white">
            <h3 class="modal-title">
                <i class="fas fa-money-bill-wave me-2"></i>
                {{ 'credit.bulk-payment-title' | translate }} - {{ selectedUser.fullName }}
            </h3>
            <button type="button" class="btn-close btn-close-white" (click)="closeBulkPaymentModal()"></button>
        </div>
        <div class="modal-body">
            <div class="mb-3">
                <span class="text-muted">{{ 'credit.total-due' | translate }}:</span>
                <strong class="ms-2">{{ getTotalDueForUser() | number:'1.2-2' }} MAD</strong>
            </div>
            <form [formGroup]="bulkPaymentForm">
                <div class="mb-3">
                    <label class="form-label">{{ 'loan.payment-amount' | translate }} *</label>
                    <input type="number" step="0.01" class="form-control" formControlName="amount" />
                </div>
                <div class="mb-3">
                    <label class="form-label">{{ 'loan.payment-date' | translate }} *</label>
                    <input type="date" class="form-control" formControlName="paymentDate" />
                </div>
                <div class="mb-3">
                    <label class="form-label">{{ 'loan.notes' | translate }}</label>
                    <textarea class="form-control" formControlName="notes" rows="2"></textarea>
                </div>
            </form>
            <div class="alert alert-info small" *ngIf="selectedUserLoans.length > 0">
                <i class="fas fa-info-circle me-1"></i>
                {{ 'credit.bulk-payment-info' | translate }}
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" (click)="closeBulkPaymentModal()">{{ 'loan.cancel' | translate }}</button>
            <button class="btn btn-success" (click)="saveBulkPayment()" 
                [disabled]="savingBulkPayment || bulkPaymentForm.invalid || getBulkPaymentAmount() > getTotalDueForUser()">
                <i class="fas" [class.fa-spinner]="savingBulkPayment" [class.fa-spin]="savingBulkPayment" [class.fa-check]="!savingBulkPayment"></i>
                {{ savingBulkPayment ? ('common.saving' | translate) : ('credit.bulk-payment-confirm' | translate) }}
            </button>
        </div>
    </div>
</div>


import { Component, OnInit, OnDestroy } from '@angular/core';
import { Subject } from 'rxjs';
import { takeUntil } from 'rxjs/operators';
import * as XLSX from 'xlsx';
import jsPDF from 'jspdf';
import 'jspdf-autotable';
import {
  CreditDashboardService,
  DashboardStats,
  UserBalance,
  Loan,
  CurrencyMetrics,
  FilterCriteria
} from './../../../services/credit-dashboard.service';
import { CurrencyService } from './../../../services/currency.service';
import { LoanService } from './../../../services/loan.service';
import { ToastService } from './../../../services/ToastService';
import { FormBuilder, FormGroup, Validators } from '@angular/forms';

/**
 * =====================================================
 * CREDIT DASHBOARD COMPONENT
 * Complete dashboard with all features
 * =====================================================
 */
@Component({
  selector: 'app-credit-dashboard',
  standalone: false,
  templateUrl: './credit-dashboard.component.html',
  styleUrls: ['./credit-dashboard.component.css']
})
export class CreditDashboardComponent implements OnInit, OnDestroy {
  Math = Math;

  // ==================== STATE MANAGEMENT ====================
  
  // Data
  stats: any | null = null;
  users: UserBalance[] = [];
  filteredUsers: UserBalance[] = [];
  currencyMetrics: CurrencyMetrics[] = [];
  selectedUserLoans: Loan[] = [];
  
  // UI State
  loading = true;
  error: string | null = null;
  selectedUser: UserBalance | null = null;
  modalOpen = false;
  bulkPaymentModalOpen = false;
  bulkPaymentForm: FormGroup;
  savingBulkPayment = false;
  
  // Filters
  searchTerm = '';
  selectedCurrency = 'all';
  selectedStatus: 'all' | 'active' | 'overdue' | 'clean' = 'all';
  sortBy: 'name' | 'balance' | 'active' | 'overdue' = 'name';
  sortOrder: 'asc' | 'desc' = 'asc';
  
  // Calculated Metrics
  currencies: string[] = [];
  totalClientsWithCredit = 0;
  totalClientsWithOverdue = 0;
  averagePaymentRate = 0;
  totalRevenue = 0;
  
  // Pagination
  currentPage = 1;
  pageSize = 10;
  totalPages = 1;
  
  // Loans list (modal) - pagination & search
  loansSearchTerm = '';
  loansPageSize = 10;
  loansCurrentPage = 1;
  loansTotalPages = 1;
  
  // Destroy subject for cleanup
  private destroy$ = new Subject<void>();

  constructor(
    private dashboardService: CreditDashboardService,
    private currencyService: CurrencyService,
    private loanService: LoanService,
    private toast: ToastService,
    private fb: FormBuilder
  ) {
    const today = new Date().toISOString().split('T')[0];
    this.bulkPaymentForm = this.fb.group({
      amount: ['', [Validators.required, Validators.min(0.01)]],
      paymentDate: [today, Validators.required],
      notes: ['']
    });
  }

  // ==================== LIFECYCLE HOOKS ====================
  
  ngOnInit(): void {
    this.loadCurrencies();
    this.loadDashboardData();
    this.subscribeToServiceState();
  }

  /**
   * Load currencies from API
   */
  loadCurrencies(): void {
    this.currencyService.getCurrencies()
      .pipe(takeUntil(this.destroy$))
      .subscribe({
        next: (response) => {
          if (response.result && Array.isArray(response.result)) {
            this.currencies = response.result.map(c => c.code);
          }
        },
        error: (err) => {
          console.error('Error loading currencies:', err);
        }
      });
  }

  ngOnDestroy(): void {
    this.destroy$.next();
    this.destroy$.complete();
  }

  // ==================== DATA LOADING ====================
  
  /**
   * Load all dashboard data
   */
  loadDashboardData(): void {
    this.loading = true;
    this.error = null;

    const statusParam = this.selectedStatus !== 'all' ? this.selectedStatus : undefined;
    const currencyParam = this.selectedCurrency !== 'all' ? this.selectedCurrency : undefined;
    const searchParam = this.searchTerm ? this.searchTerm.trim() : undefined;
    
    this.dashboardService.refreshDashboard(statusParam, currencyParam, undefined, undefined, searchParam)
      .pipe(takeUntil(this.destroy$))
      .subscribe({
        next: (data) => {
          this.stats = data.stats;
          this.users = data.users;
          this.filteredUsers = [...this.users];
          this.currencyMetrics = data.currencyMetrics || [];
          
          // Calculate company metrics
          const companyMetrics = this.dashboardService.calculateCompanyMetrics(
            data.stats,
            data.users
          );
          this.totalClientsWithCredit = companyMetrics.totalClientsWithCredit;
          this.totalClientsWithOverdue = companyMetrics.totalClientsWithOverdue;
          this.averagePaymentRate = companyMetrics.averagePaymentRate;
          this.totalRevenue = companyMetrics.totalRevenue;
          
          // Update pagination
          this.currentPage = 1;
          this.updatePagination();
          
          this.loading = false;
        },
        error: (err) => {
          console.error('Error loading dashboard:', err);
          this.error = 'Erreur lors du chargement des données';
          this.loading = false;
        }
      });
  }

  /**
   * Refresh dashboard data
   */
  refreshDashboard(): void {
    this.loadDashboardData();
  }

  /**
   * Subscribe to service state changes
   */
  private subscribeToServiceState(): void {
    this.dashboardService.loading$
      .pipe(takeUntil(this.destroy$))
      .subscribe(loading => {
        this.loading = loading;
      });

    this.dashboardService.error$
      .pipe(takeUntil(this.destroy$))
      .subscribe(error => {
        this.error = error;
      });
  }

  // ==================== FILTERING ====================
  
  /**
   * Handle search input - uses backend search
   */
  onSearch(): void {
    this.loadDashboardData();
  }

  /**
   * Handle currency filter change - uses backend filter
   */
  onCurrencyFilter(currency: string): void {
    this.selectedCurrency = currency;
    this.loadDashboardData();
  }

  /**
   * Handle status filter change - uses backend filter
   */
  onStatusFilter(status: 'all' | 'active' | 'overdue' | 'clean'): void {
    this.selectedStatus = status;
    this.loadDashboardData();
  }

  /**
   * Handle sort change
   */
  onSort(sortBy: 'name' | 'balance' | 'active' | 'overdue'): void {
    if (this.sortBy === sortBy) {
      // Toggle sort order
      this.sortOrder = this.sortOrder === 'asc' ? 'desc' : 'asc';
    } else {
      this.sortBy = sortBy;
      this.sortOrder = 'asc';
    }
    this.applyFilters();
  }

  /**
   * Apply all filters
   */
  applyFilters(): void {
    const criteria: FilterCriteria = {
      searchTerm: this.searchTerm,
      currency: this.selectedCurrency,
      status: this.selectedStatus,
      sortBy: this.sortBy,
      sortOrder: this.sortOrder
    };

    this.filteredUsers = this.dashboardService.filterUsers(this.users, criteria);
    this.currentPage = 1;
    this.updatePagination();
  }

  /**
   * Clear all filters and reload data
   */
  clearFilters(): void {
    this.searchTerm = '';
    this.selectedCurrency = 'all';
    this.selectedStatus = 'all';
    this.sortBy = 'name';
    this.sortOrder = 'asc';
    this.currentPage = 1;
    this.loadDashboardData();
  }

  // ==================== PAGINATION ====================
  
  /**
   * Update pagination
   */
  updatePagination(): void {
    this.totalPages = Math.ceil(this.filteredUsers.length / this.pageSize);
  }

  /**
   * Get paginated users
   */
  getPaginatedUsers(): UserBalance[] {
    const start = (this.currentPage - 1) * this.pageSize;
    const end = start + this.pageSize;
    return this.filteredUsers.slice(start, end);
  }

  /**
   * Go to next page
   */
  nextPage(): void {
    if (this.currentPage < this.totalPages) {
      this.currentPage++;
    }
  }

  /**
   * Go to previous page
   */
  previousPage(): void {
    if (this.currentPage > 1) {
      this.currentPage--;
    }
  }

  /**
   * Go to specific page
   */
  goToPage(page: number): void {
    if (page >= 1 && page <= this.totalPages) {
      this.currentPage = page;
    }
  }

  // ==================== USER DETAILS ====================
  
  /**
   * View user details
   */
  viewUserDetails(user: UserBalance): void {
    this.selectedUser = user;
    this.modalOpen = true;
    this.loansSearchTerm = '';
    this.loansCurrentPage = 1;
    
    // Load user loans
    this.dashboardService.getUserLoans(user.userId)
      .pipe(takeUntil(this.destroy$))
      .subscribe({
        next: (loans) => {
          this.selectedUserLoans = loans;
          this.updateLoansPagination();
        },
        error: (err) => {
          console.error('Error loading user loans:', err);
        }
      });
  }

  /**
   * Close user details modal
   */
  closeModal(): void {
    this.selectedUser = null;
    this.selectedUserLoans = [];
    this.modalOpen = false;
    this.bulkPaymentModalOpen = false;
  }

  /**
   * Get total due for selected user (sum of remaining on ACTIVE/OVERDUE loans)
   */
  getTotalDueForUser(): number {
    if (!this.selectedUserLoans?.length) return 0;
    return this.selectedUserLoans
      .filter(l => l.status === 'ACTIVE' || l.status === 'OVERDUE')
      .reduce((sum, l) => sum + this.getLoanRemaining(l), 0);
  }

  /**
   * Open bulk payment modal
   */
  openBulkPaymentModal(): void {
    if (!this.selectedUser) return;
    const today = new Date().toISOString().split('T')[0];
    this.bulkPaymentForm.reset({
      amount: this.getTotalDueForUser() || '',
      paymentDate: today,
      notes: ''
    });
    this.bulkPaymentModalOpen = true;
  }

  /**
   * Save bulk payment
   */
  saveBulkPayment(): void {
    if (!this.selectedUser || this.bulkPaymentForm.invalid || this.savingBulkPayment) return;
    const totalDue = this.getTotalDueForUser();
    const amount = Number(this.bulkPaymentForm.value.amount);
    if (amount <= 0 || amount > totalDue) {
      this.toast.showError('Le montant doit être entre 0 et le total dû (' + totalDue + ')');
      return;
    }
    this.savingBulkPayment = true;
    const paymentDate = this.bulkPaymentForm.value.paymentDate;
    const notes = this.bulkPaymentForm.value.notes || undefined;
    this.loanService.bulkPayment(this.selectedUser.userId, amount, paymentDate, notes)
      .pipe(takeUntil(this.destroy$))
      .subscribe({
        next: (res) => {
          this.savingBulkPayment = false;
          this.bulkPaymentModalOpen = false;
          this.toast.showSuccess('Paiement groupé enregistré');
          this.loadDashboardData();
          this.viewUserDetails(this.selectedUser!);
        },
        error: (err) => {
          this.savingBulkPayment = false;
          const msg = err?.error?.message || err?.error?.errors?.[0]?.messageFr || 'Erreur';
          this.toast.showError(msg);
        }
      });
  }

  closeBulkPaymentModal(): void {
    this.bulkPaymentModalOpen = false;
  }

  getBulkPaymentAmount(): number {
    const v = this.bulkPaymentForm?.value?.amount;
    if (v === '' || v == null) return 0;
    return parseFloat(String(v)) || 0;
  }

  // ==================== EXPORT FUNCTIONS ====================
  
  /**
   * Export to Excel
   */
  exportToExcel(): void {
    const workbook = XLSX.utils.book_new();

    // Sheet 1: Company Overview
    const overviewData = [
      ['TABLEAU DE BORD CRÉDIT - VUE D\'ENSEMBLE'],
      ['Date:', new Date().toLocaleDateString('fr-FR')],
      [''],
      ['MÉTRIQUES GÉNÉRALES'],
      ['Total Clients', this.stats?.totalUsers || 0],
      ['Clients avec Crédit', this.totalClientsWithCredit],
      ['Clients avec Retard', this.totalClientsWithOverdue],
      ['Crédits Actifs', this.stats?.totalActiveLoans || 0],
      ['Crédits en Retard', this.stats?.totalOverdueLoans || 0],
      ['Taux de Paiement Moyen', `${this.averagePaymentRate.toFixed(2)}%`],
      ['Revenu Total', this.totalRevenue.toFixed(2)],
      [''],
      ['DÉTAILS PAR DEVISE'],
      ['Devise', 'Total Prêté', 'Total Payé', 'Reste à Payer', '% Payé', 'Nb Clients', 'Moyenne/Client']
    ];

    this.currencyMetrics.forEach(cm => {
      overviewData.push([
        cm.currency,
        cm.totalLoaned,
        cm.totalPaid,
        cm.totalRemaining,
        `${cm.percentagePaid.toFixed(2)}%`,
        cm.clientCount,
        cm.averagePerClient
      ]);
    });

    const overviewSheet = XLSX.utils.aoa_to_sheet(overviewData);
    XLSX.utils.book_append_sheet(workbook, overviewSheet, 'Vue d\'ensemble');

    // Sheet 2: Client Details
    const clientData = this.filteredUsers.map(user => {
      const row: any = {
        'ID': user.userId,
        'Nom Complet': user.fullName,
        'CIN': user.cin,
        'Email': user.email,
        'Téléphone': user.phoneNumber,
        'Crédits Actifs': user.activeLoanCount,
        'Crédits en Retard': user.overdueLoanCount,
        'Total Crédits': user.activeLoanCount + user.overdueLoanCount
      };
      
      // Add currency columns
      this.currencies.forEach(currency => {
        row[`Solde ${currency}`] = user.balancesByCurrency?.[currency] || 0;
      });
      
      return row;
    });

    const clientSheet = XLSX.utils.json_to_sheet(clientData);
    XLSX.utils.book_append_sheet(workbook, clientSheet, 'Détails Clients');

    // Sheet 3: Currency Analysis
    const currencyData = this.currencyMetrics.map(cm => ({
      'Devise': cm.currency,
      'Montant Total Prêté': cm.totalLoaned,
      'Montant Payé': cm.totalPaid,
      'Montant Restant': cm.totalRemaining,
      'Pourcentage Payé': `${cm.percentagePaid.toFixed(2)}%`,
      'Nombre de Clients': cm.clientCount,
      'Montant Moyen par Client': cm.averagePerClient
    }));

    const currencySheet = XLSX.utils.json_to_sheet(currencyData);
    XLSX.utils.book_append_sheet(workbook, currencySheet, 'Analyse Devises');

    // Export file
    const fileName = `dashboard_credit_${new Date().toISOString().split('T')[0]}.xlsx`;
    XLSX.writeFile(workbook, fileName);
  }

  /**
   * Export to PDF
   */
  exportToPDF(): void {
