<!-- Loan Modal (Add/Edit) - Opens After Customer Selection -->
<div class="modal fade loan-modal" id="loanModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-hand-holding-usd me-2"></i>
                    {{ formMode === 'add' ? ('loan.new-credit' | translate) : ('loan.edit-credit' | translate) }}
                </h5>
                <button type="button" class="btn-close" (click)="hideModal()"></button>
            </div>

            <form [formGroup]="loanForm" (ngSubmit)="saveLoan()">
                <div class="modal-body">
                    <!-- Selected Customer Display -->
                    <div class="mb-3" *ngIf="selectedCustomer">
                        <label class="form-label">{{ 'loan.selected-customer' | translate }}</label>
                        <div class="selected-customer-card">
                            <div class="customer-avatar-sm">
                                {{ getInitials(selectedCustomer.fullName) }}
                            </div>
                            <div class="flex-grow-1">
                                <div class="customer-name-sm">{{ selectedCustomer.fullName }}</div>
                                <small class="text-muted">{{ selectedCustomer.email }}</small>
                            </div>
                            <span class="badge bg-success">
                                <i class="fas fa-check me-1"></i>
                                {{ 'loan.selected' | translate }}
                            </span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <!-- Amount -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.amount' | translate }} *</label>
                            <input type="number" class="form-control" formControlName="amount" placeholder="10000" />
                            <div class="invalid-feedback"
                                *ngIf="loanForm.get('amount')?.invalid && loanForm.get('amount')?.touched">
                                {{ 'loan.error-amount-required' | translate }}
                            </div>
                        </div>

                        <!-- Currency -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'common.currency' | translate }} *</label>
                            <select class="form-select" formControlName="currency">
                                <option *ngFor="let curr of currencies" [value]="curr">
                                    {{ curr }}
                                </option>
                            </select>
                        </div>

                        <!-- Direction (bureau→client / client→bureau) -->
                        <div class="col-12">
                            <label class="form-label">{{ 'loan.direction-label' | translate }}</label>
                            <div class="btn-group w-100" role="group">
                                <button type="button" class="btn" [class.btn-outline-primary]="loanForm.get('direction')?.value !== 'BUREAU_TO_CLIENT'"
                                    [class.btn-primary]="loanForm.get('direction')?.value === 'BUREAU_TO_CLIENT'"
                                    (click)="loanForm.patchValue({ direction: 'BUREAU_TO_CLIENT' })">
                                    <span class="me-1">↗</span> {{ 'loan.direction-bureau-to-client' | translate }}
                                </button>
                                <button type="button" class="btn" [class.btn-outline-warning]="loanForm.get('direction')?.value !== 'CLIENT_TO_BUREAU'"
                                    [class.btn-warning]="loanForm.get('direction')?.value === 'CLIENT_TO_BUREAU'"
                                    (click)="loanForm.patchValue({ direction: 'CLIENT_TO_BUREAU' })">
                                    <span class="me-1">↙</span> {{ 'loan.direction-client-to-bureau' | translate }}
                                </button>
                            </div>
                            <div class="alert alert-warning mt-2 py-2 small mb-0" *ngIf="loanForm.get('direction')?.value === 'CLIENT_TO_BUREAU'">
                                <i class="fas fa-info-circle me-1"></i> {{ 'loan.direction-warning' | translate }}
                            </div>
                        </div>

                        <!-- Loan Type -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.type' | translate }}</label>
                            <select class="form-select" formControlName="loanType">
                                <option *ngFor="let opt of loanTypeOptions" [value]="opt.value">
                                    {{ opt.labelKey | translate }}
                                </option>
                            </select>
                        </div>

                        <!-- Lender Name -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.lender-name' | translate }}</label>
                            <input type="text" class="form-control" formControlName="lenderName"
                                [placeholder]="'loan.lender-placeholder' | translate" />
                        </div>

                        <!-- Exchange Rate (when currency is not MAD) -->
                        <div class="col-md-6" *ngIf="loanForm.get('currency')?.value !== 'MAD'">
                            <label class="form-label">{{ 'loan.exchange-rate' | translate }}</label>
                            <input type="number" step="0.000001" class="form-control" formControlName="exchangeRate"
                                placeholder="1.0" />
                        </div>

                        <!-- Issue Date -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.emission-date' | translate }} *</label>
                            <input type="date" class="form-control" formControlName="issueDate" />
                        </div>

                        <!-- Due Date (optional) -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.deadline' | translate }}</label>
                            <input type="date" class="form-control" formControlName="dueDate" />
                        </div>

                        <!-- Status (only for edit) -->
                        <div class="col-md-6" *ngIf="formMode === 'edit'">
                            <label class="form-label">{{ 'loan.status' | translate }} *</label>
                            <select class="form-select" formControlName="status">
                                <option value="ACTIVE">{{ 'loan.status-active' | translate }}</option>
                                <option value="OVERDUE">{{ 'loan.status-overdue' | translate }}</option>
                                <option value="REPAID">{{ 'loan.status-repaid' | translate }}</option>
                                <option value="CANCELED">{{ 'loan.status-canceled' | translate }}</option>
                            </select>
                        </div>

                        <!-- Collateral -->
                        <div class="col-12">
                            <label class="form-label">{{ 'loan.collateral' | translate }}</label>
                            <input type="text" class="form-control" formControlName="collateral"
                                [placeholder]="'loan.collateral-placeholder' | translate" />
                        </div>

                        <!-- Notes -->
                        <div class="col-12">
                            <label class="form-label">{{ 'loan.notes' | translate }}</label>
                            <textarea class="form-control" formControlName="notes" rows="3"
                                [placeholder]="'loan.notes-placeholder' | translate"></textarea>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" (click)="hideModal()">
                        <i class="fas fa-times me-2"></i>
                        {{ 'loan.cancel' | translate }}
                    </button>
                    <button type="submit" class="btn btn-primary" [disabled]="savingLoan || !selectedCustomer">
                        <span *ngIf="savingLoan">
                            <i class="fas fa-spinner fa-spin me-2"></i>
                            {{ 'common.saving' | translate }}
                        </span>
                        <span *ngIf="!savingLoan">
                            <i class="fas fa-save me-2"></i>
                            {{ formMode === 'add' ? ('loan.create-credit' | translate) : ('loan.save' | translate) }}
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Customer Modal -->
<div class="modal fade add-customer-modal" id="addCustomerModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-user-plus me-2"></i>
                    {{ 'loan.new-customer' | translate }}
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form [formGroup]="customerForm" (ngSubmit)="saveNewCustomer()">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">{{ 'loan.full-name' | translate }} *</label>
