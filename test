            </div>
            <div class="modal-body" *ngIf="selectedLoanForPayment">
                <div class="mb-3">
                    <span class="text-muted">{{ 'loan.client' | translate }}:</span>
                    <strong>{{ selectedLoanForPayment.customerName }}</strong>
                </div>
                <div class="mb-3">
                    <span class="text-muted">{{ 'loan.amount' | translate }} {{ 'loan.remaining' | translate }}:</span>
                    <strong>{{ formatAmount(getRemaining(selectedLoanForPayment), selectedLoanForPayment.currency) }}</strong>
                </div>
                <div class="mb-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>{{ 'loan.paid' | translate }}: {{ formatAmount(selectedLoanForPayment.paidAmount ?? 0, selectedLoanForPayment.currency) }}</span>
                        <span>{{ ((selectedLoanForPayment.paidAmount ?? 0) / selectedLoanForPayment.amount * 100) | number:'1.0-0' }}%</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" [style.width.%]="((selectedLoanForPayment.paidAmount ?? 0) / selectedLoanForPayment.amount * 100)"></div>
                    </div>
                </div>

                <form [formGroup]="paymentForm">
                    <div class="mb-3">
                        <label class="form-label">{{ 'loan.payment-amount' | translate }} *</label>
                        <input type="number" step="0.01" class="form-control" formControlName="amount"
                            [placeholder]="'loan.payment-amount-placeholder' | translate" />
                        <div class="invalid-feedback d-block" *ngIf="paymentForm.get('amount')?.touched && paymentForm.get('amount')?.invalid">
                            {{ 'loan.error-amount-required' | translate }}
                        </div>
                        <small class="text-danger" *ngIf="getPaymentAmount() > 0 && getPaymentAmount() > getRemaining(selectedLoanForPayment)">
                            {{ 'loan.error-amount-exceeds-remaining' | translate }}
                        </small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ 'loan.payment-date' | translate }} *</label>
                        <input type="date" class="form-control" formControlName="paymentDate" />
