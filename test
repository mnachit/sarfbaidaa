                    [disabled]="savingPayment || paymentForm.invalid || (selectedLoanForPayment && getPaymentAmount() > getRemaining(selectedLoanForPayment))">
                    <i class="fas" [class.fa-spinner]="savingPayment" [class.fa-spin]="savingPayment" [class.fa-check]="!savingPayment"></i>
