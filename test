  // ==================== UTILITY METHODS ====================
  
  /**
   * Get currency keys
   */
  getCurrencyKeys(obj: { [key: string]: number } | undefined): string[] {
    return Object.keys(obj || {});
  }

  /**
   * Currencies for client balance blocks (union of owedByClient, owedByBureau, netByCurrency)
   */
  getClientBalanceCurrencies(): string[] {
    if (!this.selectedUser) return [];
    const s = new Set<string>();
    ['owedByClient', 'owedByBureau', 'netByCurrency'].forEach(prop => {
      const m = (this.selectedUser as any)[prop];
      if (m && typeof m === 'object') Object.keys(m).forEach(k => s.add(k));
    });
    return Array.from(s);
  }

  /**
   * Net amount for client in given currency
   */
  getClientNetAmount(currency: string): number {
    if (!this.selectedUser?.netByCurrency) return 0;
    return this.selectedUser.netByCurrency[currency] ?? 0;
  }

  /**
   * Filtered loans (search) - sorted by issueDate desc (most recent first)
   */
  getFilteredLoans(): Loan[] {
    if (!this.selectedUserLoans?.length) return [];
    let list = [...this.selectedUserLoans].sort((a, b) => {
      const da = (a.issueDate || '').toString();
      const db = (b.issueDate || '').toString();
      return db.localeCompare(da);
    });
    const q = (this.loansSearchTerm || '').trim().toLowerCase();
    if (q) {
      list = list.filter(l =>
        String(l.id).includes(q) ||
        String(l.amount).includes(q) ||
        (l.status || '').toLowerCase().includes(q) ||
        (l.currency || '').toLowerCase().includes(q) ||
        (l.issueDate || '').toLowerCase().includes(q) ||
        (l.dueDate || '').toLowerCase().includes(q) ||
        (l.lenderName || '').toLowerCase().includes(q) ||
        (l.loanType || '').toLowerCase().includes(q)
      );
    }
    return list;
  }

  /**
   * Paginated loans (10 per page)
   */
  getPaginatedLoans(): Loan[] {
    const filtered = this.getFilteredLoans();
    const start = (this.loansCurrentPage - 1) * this.loansPageSize;
    return filtered.slice(start, start + this.loansPageSize);
  }

  updateLoansPagination(): void {
    const n = this.getFilteredLoans().length;
    this.loansTotalPages = Math.max(1, Math.ceil(n / this.loansPageSize));
    if (this.loansCurrentPage > this.loansTotalPages) {
      this.loansCurrentPage = 1;
    }
  }

  onLoansSearch(): void {
    this.loansCurrentPage = 1;
    this.updateLoansPagination();
  }

  loansNextPage(): void {
    if (this.loansCurrentPage < this.loansTotalPages) this.loansCurrentPage++;
  }

  loansPrevPage(): void {
    if (this.loansCurrentPage > 1) this.loansCurrentPage--;
  }

  /**
   * Get user initials
   */
  getInitials(name: string): string {
    return this.dashboardService.getInitials(name);
  }

  /**
   * Format currency
   */
  formatCurrency(amount: number, currency: string): string {
    return this.dashboardService.formatCurrency(amount, currency);
  }

  /**
   * Format date
   */
  formatDate(date: string | Date): string {
    return this.dashboardService.formatDate(date);
  }

  /**
   * Get currency icon
   */
  getCurrencyIcon(currency: string): string {
    return this.dashboardService.getCurrencyIcon(currency);
  }

  /**
   * Get percentage paid for a currency
   */
  getCurrencyPercentage(currency: string): number {
    const metric = this.currencyMetrics.find(m => m.currency === currency);
    return metric?.percentagePaid || 0;
  }

  /**
   * Get status class for user row
   */
  getUserStatusClass(user: UserBalance): string {
    if (user.overdueLoanCount > 0) return 'status-overdue';
    if (user.activeLoanCount > 0) return 'status-active';
    return 'status-clean';
  }

  /**
   * Get loan status badge class
   */
  getLoanStatusClass(status: string): string {
    const classMap: { [key: string]: string } = {
      'ACTIVE': 'badge-success',
      'OVERDUE': 'badge-danger',
      'REPAID': 'badge-info',
      'CANCELED': 'badge-secondary'
    };
    return classMap[status] || 'badge-secondary';
  }

  /**
   * F03: Ne pas sommer devises différentes (EUR+MAD+USD = non-sens).
   * Retourne le premier solde non-nul ou 0. Affichage par devise dans le template.
   */
  getUserTotalBalance(user: UserBalance): number {
    const balances = user.balancesByCurrency || {};
    const keys = Object.keys(balances);
    if (keys.length === 0) return 0;
    if (keys.length === 1) return balances[keys[0]] ?? 0;
    return 0; // Plusieurs devises → afficher par devise, pas de somme
  }

  /**
   * Check if has filters active
   */
  hasActiveFilters(): boolean {
    return this.searchTerm !== '' || 
           this.selectedCurrency !== 'all' || 
           this.selectedStatus !== 'all';
  }

  /**
   * Montant restant dû pour un prêt (amount - paidAmount)
   */
  getLoanRemaining(loan: { amount: number; paidAmount?: number }): number {
    const paid = loan.paidAmount ?? 0;
    return Math.max(0, (loan.amount ?? 0) - paid);
  }

  /**
   * Get filter summary text
   */
  getFilterSummary(): string {
    const parts: string[] = [];
    
    if (this.searchTerm) {
      parts.push(`recherche: "${this.searchTerm}"`);
    }
    if (this.selectedCurrency !== 'all') {
      parts.push(`devise: ${this.selectedCurrency}`);
    }
    if (this.selectedStatus !== 'all') {
      const statusLabels = {
        'active': 'avec crédits actifs',
        'overdue': 'avec retards',
        'clean': 'sans crédit'
      };
      parts.push(`statut: ${statusLabels[this.selectedStatus]}`);
    }
    
    return parts.length > 0 ? parts.join(', ') : 'Aucun filtre';
  }
}


<!-- Loading Overlay -->
<app-loading-spinner [visible]="loading" [message]="'loan.loading' | translate"></app-loading-spinner>

<div class="loan-container">
    <!-- Page Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-icon">
                <i class="fas fa-hand-holding-usd"></i>
            </div>
            <div class="header-text">
                <h1>{{ 'loan.title' | translate }}</h1>
                <p>{{ 'loan.subtitle' | translate }}</p>
            </div>
        </div>
        <div class="header-actions">
            <button class="btn-header" (click)="showNewLoan()">
                <i class="fas fa-plus me-2"></i>
                {{ 'loan.new-credit' | translate }}
            </button>
        </div>
    </div>

    <!-- Stats Cards -->
    <!-- Filter Card -->
    <div class="card filter-card">
        <div class="card-body">
            <div class="row g-3">
                <!-- Search Box -->
                <div class="col-md-6">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" class="form-control" [placeholder]="'loan.search-placeholder' | translate"
                            [(ngModel)]="searchTerm" (keyup.enter)="onSearch()" />
                    </div>
                </div>

                <!-- Search Button -->
                <div class="col-md-3">
                    <button class="btn btn-primary w-100" (click)="onSearch()">
                        <i class="fas fa-search me-2"></i>
                        {{ 'loan.search' | translate }}
                    </button>
                </div>

                <!-- Advanced Filters Toggle -->
                <div class="col-md-3">
                    <button class="btn btn-outline-secondary w-100" (click)="toggleAdvancedFilters()">
                        <i class="fas fa-sliders-h me-2"></i>
                        {{ 'loan.advanced-filters' | translate }}
                    </button>
                </div>

                <!-- Status Filter Bar -->
                <div class="col-12">
                    <div class="status-bar">
                        <button *ngFor="let status of statusOptions" 
                            type="button"
                            class="status-btn"
                            [class.active]="statusFilter === status.value" 
                            (click)="onStatusChange(status.value); $any($event.target).blur()">
                            <span class="status-icon">
                                <i [class]="status.icon"></i>
                            </span>
                            <span>{{ status.labelKey | translate }}</span>
                        </button>
                    </div>
                </div>

                <!-- Advanced Filters -->
                <div class="col-12" *ngIf="showAdvancedFilters">
                    <div class="advanced-filters">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">{{ 'common.currency' | translate }}</label>
                                <select class="form-select" [(ngModel)]="currencyFilter">
                                    <option value="all">{{ 'credit.all-currencies' | translate }}</option>
                                    <option *ngFor="let curr of currencies" [value]="curr">
                                        {{ curr }}
                                    </option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">{{ 'loan.amount-min' | translate }}</label>
                                <input type="number" class="form-control" [(ngModel)]="amountMin" placeholder="0" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">{{ 'loan.amount-max' | translate }}</label>
                                <input type="number" class="form-control" [(ngModel)]="amountMax"
                                    placeholder="1000000" />
                            </div>

                            <div class="col-12">
                                <button class="btn btn-primary me-2" (click)="applyAdvancedFilters()">
                                    <i class="fas fa-filter me-2"></i>
                                    {{ 'loan.apply' | translate }}
                                </button>
                                <button class="btn btn-outline-secondary" (click)="resetFilters()">
                                    <i class="fas fa-redo me-2"></i>
                                    {{ 'loan.reset' | translate }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card table-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table loans-table mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>{{ 'loan.client' | translate }}</th>
                            <th>{{ 'loan.cin' | translate }}</th>
                            <th>{{ 'loan.contact' | translate }}</th>
                            <th>{{ 'loan.type' | translate }}</th>
                            <th>{{ 'loan.amount' | translate }}</th>
                            <th>{{ 'loan.remaining' | translate }}</th>
                            <th>{{ 'loan.emission-date' | translate }}</th>
                            <th>{{ 'loan.deadline' | translate }}</th>
                            <th>{{ 'loan.status' | translate }}</th>
                            <th class="text-center">{{ 'loan.actions' | translate }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr *ngFor="let loan of filteredLoans" class="fade-in"
                            [class.row-overdue]="loan.status === 'OVERDUE'"
                            [class.row-due-soon]="isDueSoon(loan.dueDate) && loan.status === 'ACTIVE'">
                            <td><strong>#{{ loan.id }}</strong></td>

                            <td>
                                <div class="customer-cell">
                                    <div class="customer-avatar">
                                        {{ getInitials(loan.customerName) }}
                                    </div>
                                    <span class="customer-name">{{ loan.customerName }}</span>
                                </div>
                            </td>

                            <td>{{ loan.cin }}</td>

                            <td>
                                <div>
                                    <i class="fas fa-envelope text-muted me-1"></i>
                                    {{ loan.email }}
                                </div>
                                <div class="text-muted small">
                                    <i class="fas fa-phone text-muted me-1"></i>
                                    {{ loan.phoneNumber }}
                                </div>
                            </td>

                            <td>
                                <span [class]="loan.direction === 'CLIENT_TO_BUREAU' ? 'text-warning' : 'text-success'" [title]="loan.direction === 'CLIENT_TO_BUREAU' ? ('loan.direction-client-to-bureau' | translate) : ('loan.direction-bureau-to-client' | translate)">
                                    {{ loan.direction === 'CLIENT_TO_BUREAU' ? '↙' : '↗' }}
                                </span>
                                <span *ngIf="loan.loanType" class="badge badge-info me-1">{{ 'loan.type-' + (loan.loanType | lowercase) | translate }}</span>
                                <span *ngIf="loan.lenderName" class="text-muted small">{{ loan.lenderName }}</span>
                                <span *ngIf="!loan.loanType && !loan.lenderName && !loan.direction">—</span>
                            </td>
                            <td>
                                <div class="amount-cell">
                                    <div class="amount">{{ formatAmount(loan.amount, loan.currency) }}</div>
                                    <small class="text-muted">
                                        {{ (loan.interestRate ?? 0) | number:'1.0-2' }}% {{ 'loan.interest' | translate }}
                                    </small>
                                </div>
                            </td>
                            <td>
                                <span class="amount">{{ formatAmount(getRemaining(loan), loan.currency) }}</span>
                                <small *ngIf="(loan.paidAmount ?? 0) > 0" class="text-muted d-block">{{ 'loan.paid' | translate }}: {{ formatAmount(loan.paidAmount ?? 0, loan.currency) }}</small>
                            </td>
                            <td>{{ formatDate(loan.issueDate) }}</td>

                            <td>
                                {{ formatDate(loan.dueDate) }}
                                <span *ngIf="isDueSoon(loan.dueDate) && loan.status === 'ACTIVE'"
                                    class="badge badge-warning ms-1">
                                    <i class="fas fa-clock me-1"></i>
                                    {{ 'loan.due-soon' | translate }}
                                </span>
                            </td>

                            <td>
                                <span [class]="getStatusBadgeClass(loan.status)">
                                    {{ 'loan.status-' + loan.status.toLowerCase() | translate }}
                                </span>
                            </td>

                            <td>
                                <div class="action-buttons">
                                    <button class="btn-action btn-edit" (click)="editLoan(loan)" [title]="'loan.edit' | translate">
                                        <i class="fas fa-edit"></i>
                                    </button>

                                    <button *ngIf="loan.status === 'ACTIVE' || loan.status === 'OVERDUE'"
                                        class="btn-action btn-payment" (click)="openPaymentModal(loan)"
                                        [title]="'loan.partial-payment' | translate">
                                        <i class="fas fa-money-bill-wave"></i>
                                    </button>

                                    <button *ngIf="loan.status === 'ACTIVE' || loan.status === 'OVERDUE'"
                                        class="btn-action btn-check" (click)="markAsRepaid(loan)"
                                        [title]="'loan.modal-repaid-title' | translate">
                                        <i class="fas fa-check"></i>
                                    </button>

                                    <button class="btn-action btn-history" (click)="openHistoryModal(loan)"
                                        [title]="'loan.payment-history' | translate">
                                        <i class="fas fa-history"></i>
                                    </button>

                                    <button class="btn-action btn-delete" (click)="deleteLoan(loan)" [title]="'loan.delete' | translate">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>

                        <tr *ngIf="filteredLoans.length === 0 && !loading">
                            <td colspan="11" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="fas fa-hand-holding-usd fa-3x mb-3"></i>
                                    <p>{{ 'loan.no-loans' | translate }}</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="pagination-container" *ngIf="totalPages > 1">
                <div class="pagination-info">
                    {{ 'common.showing' | translate }} {{ (currentPage * itemsPerPage) + 1 }} -
                    {{ Math.min((currentPage + 1) * itemsPerPage, totalElements) }}
                    {{ 'common.of' | translate }} {{ totalElements }}
                </div>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item" [class.disabled]="currentPage === 0">
                            <a class="page-link" (click)="goToPage(currentPage - 1)" role="button">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>

                        <li *ngFor="let page of getPaginationRange()" class="page-item"
                            [class.active]="page === currentPage">
                            <a class="page-link" (click)="goToPage(page)" role="button">
                                {{ page + 1 }}
                            </a>
                        </li>

                        <li class="page-item" [class.disabled]="currentPage === totalPages - 1">
                            <a class="page-link" (click)="goToPage(currentPage + 1)" role="button">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Customer Selection Modal - Opens First -->
