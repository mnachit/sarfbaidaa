        try {
            Company company = userService.getCompanyByUserId(userId, token);
            Response<CreditDashboardDTO> response = new Response<>();
            CreditDashboardDTO dashboard = (status != null || currency != null || startDate != null || endDate != null || search != null)
                    ? loanService.getCreditDashboardFiltered(company, userId, status, currency, startDate, endDate, search)
