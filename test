                </button>
            </div>
        </div>
    </div>
</div>


import { Component, OnInit, OnDestroy } from '@angular/core';
import { Subject } from 'rxjs';
import { takeUntil } from 'rxjs/operators';
import {
  ManagerDashboardService,
  ManagerDashboard,
  UserLoanStats,
  ClientDebt,
  OverdueLoan,
  TreasuryAccount
} from '../../services/manager-dashboard.service';
import { LanguageService } from '../../services/language.service';

@Component({
  selector: 'app-manager-dashboard',
  standalone: false,
  templateUrl: './manager-dashboard.component.html',
  styleUrls: ['./manager-dashboard.component.css']
})
export class ManagerDashboardComponent implements OnInit, OnDestroy {
  
  Math = Math; // Expose Math for template
  private destroy$ = new Subject<void>();
  
  loading = true;
  error: string | null = null;
  
  dashboard: ManagerDashboard | null = null;
  
  // Active tabs
  activeTab: 'users' | 'clients' | 'overdue' = 'users';
  
  // Pagination for users table
  usersPage = 1;
  usersPageSize = 5;
  
  // Pagination for clients table
  clientsPage = 1;
  clientsPageSize = 5;
  
  // Pagination for overdue table
  overduePage = 1;
  overduePageSize = 5;
  
  // Search filters
  userSearchTerm = '';
  clientSearchTerm = '';
  overdueSearchTerm = '';
  
  // Modal
  selectedUser: UserLoanStats | null = null;
  showUserModal = false;

  constructor(
    private dashboardService: ManagerDashboardService,
    private languageService: LanguageService
  ) {}

  ngOnInit(): void {
    this.loadDashboard();
    
    this.dashboardService.loading$
      .pipe(takeUntil(this.destroy$))
      .subscribe(loading => this.loading = loading);
      
    this.dashboardService.error$
      .pipe(takeUntil(this.destroy$))
      .subscribe(error => this.error = error);
  }

  ngOnDestroy(): void {
    this.destroy$.next();
    this.destroy$.complete();
  }

  loadDashboard(): void {
    this.dashboardService.getManagerDashboard()
      .pipe(takeUntil(this.destroy$))
      .subscribe({
        next: (data) => {
          this.dashboard = data;
          this.loading = false;
        },
        error: (err) => {
          console.error('Error loading manager dashboard:', err);
          this.loading = false;
        }
      });
  }

  refreshDashboard(): void {
    this.loading = true;
    this.loadDashboard();
  }

  setActiveTab(tab: 'users' | 'clients' | 'overdue'): void {
    this.activeTab = tab;
  }

  // Filtered Users
  get filteredUsers(): UserLoanStats[] {
    if (!this.dashboard?.userStats) return [];
    if (!this.userSearchTerm) return this.dashboard.userStats;
    
    const term = this.userSearchTerm.toLowerCase();
    return this.dashboard.userStats.filter(u => 
      u.fullName.toLowerCase().includes(term) ||
      u.email.toLowerCase().includes(term)
    );
  }

  get pagedUsers(): UserLoanStats[] {
    const start = (this.usersPage - 1) * this.usersPageSize;
    return this.filteredUsers.slice(start, start + this.usersPageSize);
  }

  get totalUsersPages(): number {
    return Math.ceil(this.filteredUsers.length / this.usersPageSize);
  }

  // Filtered Clients
  get filteredClients(): ClientDebt[] {
    if (!this.dashboard?.topDebtClients) return [];
    if (!this.clientSearchTerm) return this.dashboard.topDebtClients;
    
    const term = this.clientSearchTerm.toLowerCase();
    return this.dashboard.topDebtClients.filter(c =>
      c.fullName.toLowerCase().includes(term) ||
      c.cin?.toLowerCase().includes(term) ||
      c.phoneNumber?.includes(term)
    );
  }

  get pagedClients(): ClientDebt[] {
    const start = (this.clientsPage - 1) * this.clientsPageSize;
    return this.filteredClients.slice(start, start + this.clientsPageSize);
  }

  get totalClientsPages(): number {
    return Math.ceil(this.filteredClients.length / this.clientsPageSize);
  }

  // Filtered Overdue Loans
  get filteredOverdueLoans(): OverdueLoan[] {
    if (!this.dashboard?.overdueLoansDetails) return [];
    if (!this.overdueSearchTerm) return this.dashboard.overdueLoansDetails;
    
    const term = this.overdueSearchTerm.toLowerCase();
    return this.dashboard.overdueLoansDetails.filter(l =>
      l.clientName.toLowerCase().includes(term) ||
      l.clientCin?.toLowerCase().includes(term) ||
      l.createdByUserName?.toLowerCase().includes(term)
    );
  }

  get pagedOverdueLoans(): OverdueLoan[] {
    const start = (this.overduePage - 1) * this.overduePageSize;
    return this.filteredOverdueLoans.slice(start, start + this.overduePageSize);
  }

  get totalOverduePages(): number {
    return Math.ceil(this.filteredOverdueLoans.length / this.overduePageSize);
  }

  // Pagination handlers
  setUsersPage(page: number): void {
    if (page >= 1 && page <= this.totalUsersPages) {
      this.usersPage = page;
    }
  }

  setClientsPage(page: number): void {
    if (page >= 1 && page <= this.totalClientsPages) {
      this.clientsPage = page;
    }
  }

  setOverduePage(page: number): void {
    if (page >= 1 && page <= this.totalOverduePages) {
      this.overduePage = page;
    }
  }

  // User Modal
  openUserDetails(user: UserLoanStats): void {
    this.selectedUser = user;
    this.showUserModal = true;
  }

  closeUserModal(): void {
    this.showUserModal = false;
    this.selectedUser = null;
  }

  // Formatting helpers
  formatCurrency(amount: number, currency: string = 'MAD'): string {
    return this.dashboardService.formatCurrency(amount, currency);
  }

  formatNumber(amount: number): string {
    return this.dashboardService.formatNumber(amount);
  }

  getInitials(name: string): string {
    return this.dashboardService.getInitials(name);
  }

  getPaymentRateClass(rate: number): string {
    if (rate >= 75) return 'rate-high';
    if (rate >= 50) return 'rate-medium';
    if (rate >= 25) return 'rate-low';
    return 'rate-critical';
  }

  getDaysOverdueClass(days: number): string {
    if (days >= 30) return 'overdue-critical';
    if (days >= 14) return 'overdue-high';
    if (days >= 7) return 'overdue-medium';
    return 'overdue-low';
  }

  /** P8 — Treasury ACTIF (solde > 0, clients owe bureau) */
  getTreasuryActifs(): TreasuryAccount[] {
    return (this.dashboard?.treasuryAccounts || []).filter(a => a.type === 'ACTIF');
  }

  /** P8 — Treasury PASSIF (solde < 0, bureau owes clients) */
  getTreasuryPassifs(): TreasuryAccount[] {
    return (this.dashboard?.treasuryAccounts || []).filter(a => a.type === 'PASSIF');
  }
}


