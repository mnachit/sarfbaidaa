import { AfterViewInit, Component, OnDestroy, OnInit } from '@angular/core';
import { FormBuilder, FormGroup, Validators } from '@angular/forms';
import { UserLoanService } from '../../services/UserLoanService';
import { ToastService } from '../../services/ToastService';
import { LanguageService } from '../../services/language.service';
import { User } from '../../models/User';
import { Subscription } from 'rxjs';

declare var bootstrap: any;

@Component({
  selector: 'app-user-loan-component',
  standalone: false,
  templateUrl: './user-loan-component.component.html',
  styleUrl: './user-loan-component.component.css'
})
export class UserLoanComponentComponent implements OnInit, AfterViewInit, OnDestroy {

  // Expose Math for template
  Math = Math;

  // Data
  users: any[] = [];
  filteredUsers: any[] = [];
  selectedUser: any | null = null;

  // Pagination
  currentPage: number = 0;
  itemsPerPage: number = 10;
  totalPages: number = 0;
  totalElements: number = 0;

  // Filters
  searchTerm: string = '';

  // Loading states
  loading: boolean = false;
  savingUser: boolean = false;

  // Forms
  userForm: FormGroup;
  formMode: 'add' | 'edit' | 'view' = 'add';
  editingUserId: number | null = null;

  // Stats
  totalUsersCount: number = 0;
  activeUsersCount: number = 0;
  usersWithLoans: number = 0;

  // Modal instances
  private userModal: any;
  private confirmModal: any;
  private detailsModal: any;

  // Confirmation Modal
  modalTitle: string = '';
  modalBody: string = '';
  modalConfirmText: string = '';
  modalHeaderClass: string = '';
  modalButtonClass: string = '';
  modalAction: 'delete' | null = null;

  // Subscriptions
  private subscriptions = new Subscription();

  constructor(
    private fb: FormBuilder,
    private userService: UserLoanService,
    private toast: ToastService,
    public languageService: LanguageService
  ) {
    // User Form - CIN required only for PARTICULIER
    this.userForm = this.fb.group({
      fullName: ['', Validators.required],
      clientType: ['PARTICULIER'],
      cin: ['', [Validators.required, Validators.minLength(5)]],
      email: ['', [Validators.required, Validators.email]],
      phoneNumber: ['', Validators.required],
      address: ['', Validators.required]
    });
    this.userForm.get('clientType')?.valueChanges.subscribe((ct) => {
      const cinCtrl = this.userForm.get('cin');
      if (ct === 'INSTITUTION') {
        cinCtrl?.clearValidators();
        cinCtrl?.setValue('');
      } else {
        cinCtrl?.setValidators([Validators.required, Validators.minLength(5)]);
      }
      cinCtrl?.updateValueAndValidity();
    });
  }

  ngOnInit(): void {
    this.loadUsers();
  }

  ngAfterViewInit(): void {
    setTimeout(() => {
      const userModalEl = document.getElementById('userModal');
      if (userModalEl) {
        this.userModal = new bootstrap.Modal(userModalEl);
      }

      const confirmModalEl = document.getElementById('confirmModal');
      if (confirmModalEl) {
        this.confirmModal = new bootstrap.Modal(confirmModalEl);
      }

      const detailsModalEl = document.getElementById('detailsModal');
      if (detailsModalEl) {
        this.detailsModal = new bootstrap.Modal(detailsModalEl);
      }
    }, 100);
  }

  ngOnDestroy(): void {
    this.subscriptions.unsubscribe();
    if (this.userModal) this.userModal.dispose();
    if (this.confirmModal) this.confirmModal.dispose();
    if (this.detailsModal) this.detailsModal.dispose();
  }

  /**
   * Load users from backend
   */
  loadUsers(): void {
    if (this.loading) return;
    this.loading = true;

    this.subscriptions.add(
      this.userService.getListUser(this.currentPage, this.itemsPerPage, this.searchTerm).subscribe({
        next: (response) => {
          this.users = response.result.content;
          this.filteredUsers = response.result.content;
          this.totalPages = response.result.totalPages;
          this.totalElements = response.result.totalElements;
          this.calculateStats();
          this.loading = false;
        },
        error: (error) => {
          console.error('Error loading users:', error);
          this.toast.showError(this.languageService.translate('loan.error-loading-clients'));
          this.loading = false;
        }
      })
    );
  }

  /**
   * Calculate statistics
   */
  calculateStats(): void {
    this.totalUsersCount = this.totalElements;
    this.activeUsersCount = this.users.filter(u => u.totalLoans && u.totalLoans > 0).length;
    this.usersWithLoans = this.users.filter(u => u.activeLoansCount && u.activeLoansCount > 0).length;
  }

  /**
   * Search functionality
   */
  onSearch(): void {
    this.currentPage = 0;
    this.loadUsers();
  }

  /**
   * Clear search
   */
  clearSearch(): void {
    this.searchTerm = '';
    this.currentPage = 0;
    this.loadUsers();
  }

  /**
   * Pagination
   */
  getPaginationRange(): number[] {
    const range: number[] = [];
    const maxPages = 5;

    if (this.totalPages <= maxPages) {
      for (let i = 0; i < this.totalPages; i++) {
        range.push(i);
      }
    } else {
      let start = Math.max(0, this.currentPage - Math.floor(maxPages / 2));
      let end = Math.min(this.totalPages - 1, start + maxPages - 1);

      if (end === this.totalPages - 1) {
        start = Math.max(0, end - maxPages + 1);
      }

      for (let i = start; i <= end; i++) {
        range.push(i);
      }
    }

    return range;
  }

  goToPage(page: number): void {
    if (page >= 0 && page < this.totalPages && page !== this.currentPage) {
      this.currentPage = page;
      this.loadUsers();
    }
  }

  /**
   * Show new user modal
   */
  showNewUser(): void {
    this.formMode = 'add';
    this.editingUserId = null;
    this.userForm.reset({
      fullName: '',
      clientType: 'PARTICULIER',
      cin: '',
      email: '',
      phoneNumber: '',
      address: ''
    });

    setTimeout(() => {
      if (this.userModal) {
        this.userModal.show();
      }
    }, 100);
  }

  /**
   * Edit user
   */
  editUser(user: User): void {
    this.formMode = 'edit';
    this.editingUserId = user.id || null;

    this.userForm.patchValue({
      fullName: user.fullName,
      clientType: (user as any).clientType || 'PARTICULIER',
      cin: user.cin || '',
      email: user.email,
      phoneNumber: user.phoneNumber,
      address: user.address
    });

    setTimeout(() => {
      if (this.userModal) {
        this.userModal.show();
      }
    }, 100);
  }

  /**
   * View user details
   */
  viewUser(user: User): void {
    this.selectedUser = user;
    this.formMode = 'view';

    setTimeout(() => {
      if (this.detailsModal) {
        this.detailsModal.show();
      }
    }, 100);
  }

  /**
   * Save user
   */
  saveUser(): void {
    if (this.userForm.invalid || this.savingUser) {
      Object.keys(this.userForm.controls).forEach(key => {
        this.userForm.get(key)?.markAsTouched();
      });
      return;
    }

    this.savingUser = true;

    const userData: User = {
      fullName: this.userForm.value.fullName,
      cin: this.userForm.value.cin || undefined,
      clientType: this.userForm.value.clientType,
      email: this.userForm.value.email,
      phoneNumber: this.userForm.value.phoneNumber,
      address: this.userForm.value.address
    };

    const apiCall = this.formMode === 'edit' && this.editingUserId
      ? this.userService.updateUser(this.editingUserId, userData)
      : this.userService.saveUser(userData);

    this.subscriptions.add(
      apiCall.subscribe({
        next: (response) => {
          this.savingUser = false;
          this.hideModal();

          const message = this.formMode === 'add'
            ? this.languageService.translate('loan.customer-created')
            : this.languageService.translate('loan.customer-updated');

          this.toast.showSuccess(message);

          setTimeout(() => {
            this.loadUsers();
          }, 300);
        },
        error: (err) => {
          this.savingUser = false;
          const backend = err?.error || err;
          let messages: string[] = [];

          if (backend?.errorMap) {
            messages = Object.entries(backend.errorMap)
              .map(([k, v]) => `${k}: ${v}`);
          } else if (Array.isArray(backend?.errors)) {
            messages = backend.errors.map((e: any) => e.message || 'Unknown error');
          } else if (backend?.message) {
            messages = [backend.message];
          } else {
            messages = [this.languageService.translate('loan.error-server')];
          }

          this.toast.showError(messages.join('\n'));
        }
      })
    );
  }

  /**
   * Delete user
   */
  deleteUser(user: User): void {
    this.modalTitle = this.languageService.translate('loan.delete-customer-title');
    this.modalBody = this.languageService.translate('loan.delete-customer-body').replace('{name}', user.fullName);
    this.modalConfirmText = this.languageService.translate('loan.delete');
    this.modalHeaderClass = 'bg-danger text-white';
    this.modalButtonClass = 'btn btn-danger';
    this.modalAction = 'delete';
    this.editingUserId = user.id || null;

    if (this.confirmModal) {
      this.confirmModal.show();
    }
  }

  /**
   * Handle modal confirmation
   */
  handleModalConfirm(): void {
    if (!this.editingUserId || this.loading) return;

    this.loading = true;

    if (this.modalAction === 'delete') {
      this.subscriptions.add(
        this.userService.deleteUser(this.editingUserId!).subscribe({
          next: () => {
            this.loading = false;
            if (this.confirmModal) this.confirmModal.hide();
            this.toast.showSuccess(this.languageService.translate('loan.customer-deleted'));
            this.loadUsers();
          },
          error: (err) => {
            this.loading = false;
            this.toast.showError(err?.error?.message || this.languageService.translate('loan.error-deleting'));
          }
        })
      );
    }

    this.modalAction = null;
    this.editingUserId = null;
  }

  /**
   * Hide modal
   */
  hideModal(): void {
    if (this.userModal) {
      this.userModal.hide();
    }

    setTimeout(() => {
      const backdrop = document.querySelector('.modal-backdrop');
      if (backdrop) backdrop.remove();
      document.body.classList.remove('modal-open');
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
    }, 200);
  }

  /**
   * Utility: Get initials
   */
  getInitials(name?: string): string {
    if (!name || typeof name !== 'string') return '';
    return name
      .trim()
      .split(' ')
      .filter(x => x.length > 0)
      .map(x => x[0])
      .join('')
      .toUpperCase();
  }

  /**
   * Utility: Get status badge class
   */
  getStatusBadgeClass(loansCount: number): string {
    if (loansCount === 0) return 'badge badge-secondary';
    if (loansCount <= 2) return 'badge badge-primary';
    if (loansCount <= 5) return 'badge badge-warning';
    return 'badge badge-danger';
  }

  /**
   * Get safe active loans count
   */
  getActiveLoansCount(user: any): number {
    return user?.activeLoansCount || 0;
  }
}