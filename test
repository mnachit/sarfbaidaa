                <p>{{ 'loan.subtitle' | translate }}</p>
            </div>
        </div>
        <div class="header-actions">
            <button class="btn-header" (click)="showNewLoan()">
                <i class="fas fa-plus me-2"></i>
                {{ 'loan.new-credit' | translate }}
            </button>
        </div>
    </div>

    <!-- Stats Cards -->
    <!-- Filter Card -->
    <div class="card filter-card">
        <div class="card-body">
            <div class="row g-3">
                <!-- Search Box -->
                <div class="col-md-6">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" class="form-control" [placeholder]="'loan.search-placeholder' | translate"
                            [(ngModel)]="searchTerm" (keyup.enter)="onSearch()" />
                    </div>
                </div>

                <!-- Search Button -->
                <div class="col-md-3">
                    <button class="btn btn-primary w-100" (click)="onSearch()">
                        <i class="fas fa-search me-2"></i>
                        {{ 'loan.search' | translate }}
                    </button>
                </div>

                <!-- Advanced Filters Toggle -->
                <div class="col-md-3">
                    <button class="btn btn-outline-secondary w-100" (click)="toggleAdvancedFilters()">
                        <i class="fas fa-sliders-h me-2"></i>
                        {{ 'loan.advanced-filters' | translate }}
                    </button>
                </div>

                <!-- Status Filter Bar -->
                <div class="col-12">
                    <div class="status-bar">
                        <button *ngFor="let status of statusOptions" 
                            type="button"
                            class="status-btn"
                            [class.active]="statusFilter === status.value" 
                            (click)="onStatusChange(status.value); $any($event.target).blur()">
                            <span class="status-icon">
                                <i [class]="status.icon"></i>
                            </span>
                            <span>{{ status.labelKey | translate }}</span>
                        </button>
                    </div>
                </div>

                <!-- Advanced Filters -->
                <div class="col-12" *ngIf="showAdvancedFilters">
                    <div class="advanced-filters">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">{{ 'common.currency' | translate }}</label>
                                <select class="form-select" [(ngModel)]="currencyFilter">
                                    <option value="all">{{ 'credit.all-currencies' | translate }}</option>
                                    <option *ngFor="let curr of currencies" [value]="curr">
                                        {{ curr }}
                                    </option>
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">{{ 'loan.amount-min' | translate }}</label>
                                <input type="number" class="form-control" [(ngModel)]="amountMin" placeholder="0" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">{{ 'loan.amount-max' | translate }}</label>
                                <input type="number" class="form-control" [(ngModel)]="amountMax"
                                    placeholder="1000000" />
                            </div>

                            <div class="col-12">
                                <button class="btn btn-primary me-2" (click)="applyAdvancedFilters()">
                                    <i class="fas fa-filter me-2"></i>
                                    {{ 'loan.apply' | translate }}
                                </button>
                                <button class="btn btn-outline-secondary" (click)="resetFilters()">
                                    <i class="fas fa-redo me-2"></i>
                                    {{ 'loan.reset' | translate }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card table-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table loans-table mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>{{ 'loan.client' | translate }}</th>
                            <th>{{ 'loan.cin' | translate }}</th>
                            <th>{{ 'loan.contact' | translate }}</th>
                            <th>{{ 'loan.type' | translate }}</th>
                            <th>{{ 'loan.amount' | translate }}</th>
                            <th>{{ 'loan.remaining' | translate }}</th>
                            <th>{{ 'loan.emission-date' | translate }}</th>
                            <th>{{ 'loan.deadline' | translate }}</th>
                            <th>{{ 'loan.status' | translate }}</th>
                            <th class="text-center">{{ 'loan.actions' | translate }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr *ngFor="let loan of filteredLoans" class="fade-in"
                            [class.row-overdue]="loan.status === 'OVERDUE'"
                            [class.row-due-soon]="isDueSoon(loan.dueDate) && loan.status === 'ACTIVE'">
                            <td><strong>#{{ loan.id }}</strong></td>

                            <td>
                                <div class="customer-cell">
                                    <div class="customer-avatar">
                                        {{ getInitials(loan.customerName) }}
                                    </div>
                                    <span class="customer-name">{{ loan.customerName }}</span>
                                </div>
                            </td>

                            <td>{{ loan.cin }}</td>

                            <td>
                                <div>
                                    <i class="fas fa-envelope text-muted me-1"></i>
                                    {{ loan.email }}
                                </div>
                                <div class="text-muted small">
                                    <i class="fas fa-phone text-muted me-1"></i>
                                    {{ loan.phoneNumber }}
                                </div>
                            </td>

                            <td>
                                <span *ngIf="loan.loanType" class="badge badge-info me-1">{{ 'loan.type-' + (loan.loanType | lowercase) | translate }}</span>
                                <span *ngIf="loan.lenderName" class="text-muted small">{{ loan.lenderName }}</span>
                                <span *ngIf="!loan.loanType && !loan.lenderName">—</span>
                            </td>
                            <td>
                                <div class="amount-cell">
                                    <div class="amount">{{ formatAmount(loan.amount, loan.currency) }}</div>
                                    <small class="text-muted">
                                        {{ loan.interestRate }}% {{ 'loan.interest' | translate }}
                                    </small>
                                </div>
                            </td>
                            <td>
                                <span class="amount">{{ formatAmount(getRemaining(loan), loan.currency) }}</span>
                                <small *ngIf="(loan.paidAmount ?? 0) > 0" class="text-muted d-block">{{ 'loan.paid' | translate }}: {{ formatAmount(loan.paidAmount ?? 0, loan.currency) }}</small>
                            </td>
                            <td>{{ formatDate(loan.issueDate) }}</td>

                            <td>
                                {{ formatDate(loan.dueDate) }}
                                <span *ngIf="isDueSoon(loan.dueDate) && loan.status === 'ACTIVE'"
                                    class="badge badge-warning ms-1">
                                    <i class="fas fa-clock me-1"></i>
                                    {{ 'loan.due-soon' | translate }}
                                </span>
                            </td>

                            <td>
                                <span [class]="getStatusBadgeClass(loan.status)">
                                    {{ 'loan.status-' + loan.status.toLowerCase() | translate }}
                                </span>
                            </td>

                            <td>
                                <div class="action-buttons">
                                    <button class="btn-action btn-edit" (click)="editLoan(loan)" [title]="'loan.edit' | translate">
                                        <i class="fas fa-edit"></i>
                                    </button>

                                    <button *ngIf="loan.status === 'ACTIVE' || loan.status === 'OVERDUE'"
                                        class="btn-action btn-check" (click)="markAsRepaid(loan)"
                                        title="Marquer remboursé">
                                        <i class="fas fa-check"></i>
                                    </button>

                                    <button class="btn-action btn-delete" (click)="deleteLoan(loan)" [title]="'loan.delete' | translate">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>

                        <tr *ngIf="filteredLoans.length === 0 && !loading">
                            <td colspan="11" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="fas fa-hand-holding-usd fa-3x mb-3"></i>
                                    <p>{{ 'loan.no-loans' | translate }}</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="pagination-container" *ngIf="totalPages > 1">
                <div class="pagination-info">
                    {{ 'common.showing' | translate }} {{ (currentPage * itemsPerPage) + 1 }} -
                    {{ Math.min((currentPage + 1) * itemsPerPage, totalElements) }}
                    {{ 'common.of' | translate }} {{ totalElements }}
                </div>

                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item" [class.disabled]="currentPage === 0">
                            <a class="page-link" (click)="goToPage(currentPage - 1)" role="button">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>

                        <li *ngFor="let page of getPaginationRange()" class="page-item"
                            [class.active]="page === currentPage">
                            <a class="page-link" (click)="goToPage(page)" role="button">
                                {{ page + 1 }}
                            </a>
                        </li>

                        <li class="page-item" [class.disabled]="currentPage === totalPages - 1">
                            <a class="page-link" (click)="goToPage(currentPage + 1)" role="button">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Customer Selection Modal - Opens First -->
<div class="modal fade customer-modal" id="customerModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-users me-2"></i>
                    {{ 'loan.select-customer' | translate }}
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- Search Box -->
            <div class="customer-search-box">
                <i class="fas fa-search"></i>
                <input type="text" class="customer-search" [placeholder]="'loan.search-client' | translate"
                    [(ngModel)]="customerSearchTerm" (input)="filterCustomers()" />
                <button type="button" class="search-clear" *ngIf="customerSearchTerm" (click)="clearCustomerSearch()">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- Add New Customer Button -->
            <div class="add-customer-action">
                <button type="button" class="btn-add-customer" (click)="goToCustomers()">
                    <i class="fas fa-plus-circle me-2"></i>
                    {{ 'loan.add-new-client' | translate }}
                </button>
            </div>

            <!-- Customer List -->
            <div class="customer-list">
                <div *ngFor="let customer of filteredCustomers" class="customer-item"
                    (click)="selectCustomer(customer)">
                    <div class="customer-avatar">
                        {{ getInitials(customer.fullName) }}
                    </div>
                    <div class="customer-details">
                        <div class="customer-name">{{ customer.fullName }}</div>
                        <div class="customer-email">
                            {{ customer.email }}
                            <span *ngIf="customer.cin"> • {{ customer.cin }}</span>
                        </div>
                    </div>
                    <i class="fas fa-chevron-right text-muted"></i>
                </div>

                <div *ngIf="filteredCustomers.length === 0" class="text-center py-4">
                    <i class="fas fa-users fa-2x text-muted mb-2"></i>
                    <p class="text-muted mb-0">{{ 'loan.no-customers' | translate }}</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loan Modal (Add/Edit) - Opens After Customer Selection -->
<div class="modal fade loan-modal" id="loanModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-hand-holding-usd me-2"></i>
                    {{ formMode === 'add' ? ('loan.new-credit' | translate) : ('loan.edit-credit' | translate) }}
                </h5>
                <button type="button" class="btn-close" (click)="hideModal()"></button>
            </div>

            <form [formGroup]="loanForm" (ngSubmit)="saveLoan()">
                <div class="modal-body">
                    <!-- Selected Customer Display -->
                    <div class="mb-3" *ngIf="selectedCustomer">
                        <label class="form-label">{{ 'loan.selected-customer' | translate }}</label>
                        <div class="selected-customer-card">
                            <div class="customer-avatar-sm">
                                {{ getInitials(selectedCustomer.fullName) }}
                            </div>
                            <div class="flex-grow-1">
                                <div class="customer-name-sm">{{ selectedCustomer.fullName }}</div>
                                <small class="text-muted">{{ selectedCustomer.email }}</small>
                            </div>
                            <span class="badge bg-success">
                                <i class="fas fa-check me-1"></i>
                                {{ 'loan.selected' | translate }}
                            </span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <!-- Amount -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.amount' | translate }} *</label>
                            <input type="number" class="form-control" formControlName="amount" placeholder="10000" />
                            <div class="invalid-feedback"
                                *ngIf="loanForm.get('amount')?.invalid && loanForm.get('amount')?.touched">
                                {{ 'loan.error-amount-required' | translate }}
                            </div>
                        </div>

                        <!-- Currency -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'common.currency' | translate }} *</label>
                            <select class="form-select" formControlName="currency">
                                <option *ngFor="let curr of currencies" [value]="curr">
                                    {{ curr }}
                                </option>
                            </select>
                        </div>

                        <!-- Loan Type -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.type' | translate }}</label>
                            <select class="form-select" formControlName="loanType">
                                <option *ngFor="let opt of loanTypeOptions" [value]="opt.value">
                                    {{ opt.labelKey | translate }}
                                </option>
                            </select>
                        </div>

                        <!-- Lender Name -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.lender-name' | translate }}</label>
                            <input type="text" class="form-control" formControlName="lenderName"
                                [placeholder]="'loan.lender-placeholder' | translate" />
                        </div>

                        <!-- Exchange Rate (when currency is not MAD) -->
                        <div class="col-md-6" *ngIf="loanForm.get('currency')?.value !== 'MAD'">
                            <label class="form-label">{{ 'loan.exchange-rate' | translate }}</label>
                            <input type="number" step="0.000001" class="form-control" formControlName="exchangeRate"
                                placeholder="1.0" />
                        </div>

                        <!-- Issue Date -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.emission-date' | translate }} *</label>
                            <input type="date" class="form-control" formControlName="issueDate" />
                        </div>

                        <!-- Due Date (optional) -->
                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.deadline' | translate }}</label>
                            <input type="date" class="form-control" formControlName="dueDate" />
                        </div>

                        <!-- Status (only for edit) -->
                        <div class="col-md-6" *ngIf="formMode === 'edit'">
                            <label class="form-label">{{ 'loan.status' | translate }} *</label>
                            <select class="form-select" formControlName="status">
                                <option value="ACTIVE">{{ 'loan.status-active' | translate }}</option>
                                <option value="OVERDUE">{{ 'loan.status-overdue' | translate }}</option>
                                <option value="REPAID">{{ 'loan.status-repaid' | translate }}</option>
                                <option value="CANCELED">{{ 'loan.status-canceled' | translate }}</option>
                            </select>
                        </div>

                        <!-- Collateral -->
                        <div class="col-12">
                            <label class="form-label">{{ 'loan.collateral' | translate }}</label>
                            <input type="text" class="form-control" formControlName="collateral"
                                [placeholder]="'loan.collateral-placeholder' | translate" />
                        </div>

                        <!-- Notes -->
                        <div class="col-12">
                            <label class="form-label">{{ 'loan.notes' | translate }}</label>
                            <textarea class="form-control" formControlName="notes" rows="3"
                                [placeholder]="'loan.notes-placeholder' | translate"></textarea>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" (click)="hideModal()">
                        <i class="fas fa-times me-2"></i>
                        {{ 'loan.cancel' | translate }}
                    </button>
                    <button type="submit" class="btn btn-primary" [disabled]="savingLoan || !selectedCustomer">
                        <span *ngIf="savingLoan">
                            <i class="fas fa-spinner fa-spin me-2"></i>
                            {{ 'common.saving' | translate }}
                        </span>
                        <span *ngIf="!savingLoan">
                            <i class="fas fa-save me-2"></i>
                            {{ formMode === 'add' ? ('loan.create-credit' | translate) : ('loan.save' | translate) }}
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Customer Modal -->
<div class="modal fade add-customer-modal" id="addCustomerModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-user-plus me-2"></i>
                    {{ 'loan.new-customer' | translate }}
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form [formGroup]="customerForm" (ngSubmit)="saveNewCustomer()">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">{{ 'loan.full-name' | translate }} *</label>
                            <input type="text" class="form-control" formControlName="fullName"
                                placeholder="Ex: Mohamed Nachit" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.cin' | translate }} *</label>
                            <input type="text" class="form-control" formControlName="cin" placeholder="Ex: AB123456" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.phone' | translate }} *</label>
                            <input type="text" class="form-control" formControlName="phoneNumber"
                                placeholder="+212 6 12 34 56 78" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">{{ 'loan.email' | translate }} *</label>
                            <input type="email" class="form-control" formControlName="email"
                                placeholder="mohamed@example.com" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">{{ 'loan.address' | translate }} *</label>
                            <textarea class="form-control" formControlName="address" rows="2"
                                placeholder="123 Rue Mohammed V, Casablanca"></textarea>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i>
                        {{ 'loan.cancel' | translate }}
                    </button>
                    <button type="submit" class="btn btn-success" [disabled]="savingCustomer || customerForm.invalid">
                        <span *ngIf="savingCustomer">
                            <i class="fas fa-spinner fa-spin me-2"></i>
                            {{ 'common.saving' | translate }}
                        </span>
                        <span *ngIf="!savingCustomer">
                            <i class="fas fa-user-check me-2"></i>
                            {{ 'loan.create' | translate }}
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" [ngClass]="modalHeaderClass">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    {{ modalTitle }}
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">{{ modalBody }}</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>
                    {{ 'loan.cancel' | translate }}
                </button>
                <button type="button" [ngClass]="modalButtonClass" (click)="handleModalConfirm()" [disabled]="loading">
                    <span *ngIf="loading">
                        <i class="fas fa-spinner fa-spin me-2"></i>
                        {{ 'common.processing' | translate }}
                    </span>
                    <span *ngIf="!loading">
                        <i class="fas fa-check me-2"></i>
                        {{ modalConfirmText }}
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>


import { Component, OnInit, AfterViewInit, OnDestroy } from '@angular/core';
import { FormBuilder, FormGroup, Validators } from '@angular/forms';
import { LoanService } from '../../services/loan.service';
import { UserLoanService } from '../../services/UserLoanService';
import { ToastService } from '../../services/ToastService';
import { CurrencyService } from '../../services/currency.service';
import { LanguageService } from '../../services/language.service';
import { Loan, LoanType, getLoanRemaining } from '../../models/loan.model';
import { User } from '../../models/User';
import { Subscription } from 'rxjs';
import { Router } from '@angular/router';

declare var bootstrap: any;

interface CurrencyTotal {
  currency: string;
  total: number;
}

@Component({
  selector: 'app-loan-management',
  standalone: false,
  templateUrl: './loan-management.component.html',
  styleUrls: ['./loan-management.component.css']
})
export class LoanManagementComponent1 implements OnInit, AfterViewInit, OnDestroy {
  
  // Expose Math for template
  Math = Math;
  
  // Data
  loans: Loan[] = [];
  filteredLoans: Loan[] = [];
  customers: User[] = [];
  filteredCustomers: User[] = [];
  selectedCustomer: User | null = null;
  
  // Pagination
  currentPage: number = 0;
  itemsPerPage: number = 10;
  totalPages: number = 0;
  totalElements: number = 0;
  
  // Filters
  searchTerm: string = '';
  statusFilter: string | null = null;
  currencyFilter: string = 'all';
  customerSearchTerm: string = '';
  showAdvancedFilters: boolean = false;
  amountMin: number | null = null;
  amountMax: number | null = null;
  
  /** Options type de prêt (INARA, CREDIT CLIENT, HAMID) */
  loanTypeOptions: { value: LoanType | ''; labelKey: string }[] = [
    { value: '', labelKey: 'loan.type-not-specified' },
    { value: 'INSTITUTIONAL', labelKey: 'loan.type-institutional' },
    { value: 'CLIENT_CREDIT', labelKey: 'loan.type-client-credit' },
    { value: 'EMPLOYEE_ADVANCE', labelKey: 'loan.type-employee-advance' }
  ];

  // Status Options - will be populated with translations
  statusOptions: { value: string | null; labelKey: string; icon: string }[] = [
    { value: null, labelKey: 'loan.status-all', icon: 'fas fa-list' },
    { value: 'ACTIVE', labelKey: 'loan.status-active', icon: 'fas fa-check-circle' },
    { value: 'OVERDUE', labelKey: 'loan.status-overdue', icon: 'fas fa-exclamation-circle' },
    { value: 'REPAID', labelKey: 'loan.status-repaid', icon: 'fas fa-coins' },
    { value: 'CANCELED', labelKey: 'loan.status-canceled', icon: 'fas fa-times-circle' }
  ];
  
  // Available currencies - loaded from backend
  currencies: string[] = [];
  
  // Loading states
  loading: boolean = false;
  savingLoan: boolean = false;
  savingCustomer: boolean = false;
  
  // Forms
  loanForm: FormGroup;
  customerForm: FormGroup;
  formMode: 'add' | 'edit' = 'add';
  editingLoanId: number | null = null;
  
  // Stats - Multi-currency
  currencyTotals: CurrencyTotal[] = [];
  activeLoansCount: number = 0;
  overdueLoansCount: number = 0;
  repaidLoansCount: number = 0;
  
  // Modal instances
  private loanModal: any;
  private customerModal: any;
  private addCustomerModal: any;
  private confirmModal: any;
  
  // Confirmation Modal
  modalTitle: string = '';
  modalBody: string = '';
  modalConfirmText: string = '';
  modalHeaderClass: string = '';
  modalButtonClass: string = '';
  modalAction: 'delete' | 'repaid' | null = null;
  
  // Subscriptions
  private subscriptions = new Subscription();
  
  constructor(
    private fb: FormBuilder,
    private loanService: LoanService,
    private userService: UserLoanService,
    private toast: ToastService,
    private router: Router,
    private currencyService: CurrencyService,
    public languageService: LanguageService
  ) {
    // Loan Form
    this.loanForm = this.fb.group({
      customerName: ['', Validators.required],
      amount: ['', [Validators.required, Validators.min(1)]],
      currency: ['MAD', Validators.required],
      loanType: [''],
      lenderName: [''],
      exchangeRate: [null as number | null],
      issueDate: [new Date().toISOString().split('T')[0], Validators.required],
      dueDate: [''],
      interestRate: [0],
      collateral: [''],
      notes: [''],
      isConfidential: [false],
      status: ['ACTIVE', Validators.required],
    });
    
    // Customer Form
    this.customerForm = this.fb.group({
      fullName: ['', Validators.required],
      cin: ['', Validators.required],
      email: ['', [Validators.required, Validators.email]],
      phoneNumber: ['', Validators.required],
      address: ['', Validators.required]
    });
  }
  
  ngOnInit(): void {
    this.loadLoans();
    this.loadCustomers();
    this.loadCurrencies();
  }
  
  /**
   * Load currencies from backend
   */
  loadCurrencies(): void {
    this.subscriptions.add(
      this.currencyService.getCurrencies().subscribe({
        next: (response) => {
          this.currencies = response.result.map(c => c.code);
        },
        error: (error) => {
          console.error('Error loading currencies:', error);
          // Fallback to default currencies
          this.currencies = ['USD', 'EUR', 'GBP', 'MAD', 'SAR', 'AED'];
        }
      })
    );
  }
  
  ngAfterViewInit(): void {
    setTimeout(() => {
      const loanModalEl = document.getElementById('loanModal');
      if (loanModalEl) {
        this.loanModal = new bootstrap.Modal(loanModalEl);
      }
      
      const customerModalEl = document.getElementById('customerModal');
      if (customerModalEl) {
        this.customerModal = new bootstrap.Modal(customerModalEl);
      }
      
      const addCustomerModalEl = document.getElementById('addCustomerModal');
      if (addCustomerModalEl) {
        this.addCustomerModal = new bootstrap.Modal(addCustomerModalEl);
      }
      
      const confirmModalEl = document.getElementById('confirmModal');
      if (confirmModalEl) {
        this.confirmModal = new bootstrap.Modal(confirmModalEl);
      }
    }, 100);
  }
  
  ngOnDestroy(): void {
    this.subscriptions.unsubscribe();
    if (this.loanModal) this.loanModal.dispose();
    if (this.customerModal) this.customerModal.dispose();
    if (this.addCustomerModal) this.addCustomerModal.dispose();
    if (this.confirmModal) this.confirmModal.dispose();
  }
  
  /**
   * Load loans from backend
   */
  loadLoans(): void {
    if (this.loading) return;
    this.loading = true;
    
    const advancedFilters = {
      amountMin: this.amountMin,
      amountMax: this.amountMax
    };
    
    this.subscriptions.add(
      this.loanService.getLoans(
        this.currentPage,
        this.itemsPerPage,
        this.searchTerm,
        this.statusFilter || 'all',
        undefined,
        this.currencyFilter,
        advancedFilters
      ).subscribe({
        next: (response) => {
          this.loans = response.loans;
          this.filteredLoans = response.loans;
          this.totalPages = response.totalPages;
          this.totalElements = response.totalElements;
          this.calculateStats();
          this.loading = false;
        },
        error: (error) => {
          console.error('Error loading loans:', error);
          this.toast.showError(this.languageService.translate('loan.error-loading'));
          this.loading = false;
        }
      })
    );
  }
  
  /**
   * Load customers for selection - paginated with backend search (max 50)
   */
  loadCustomers(searchTerm?: string): void {
    this.subscriptions.add(
      this.userService.getListUser(0, 50, searchTerm ?? '').subscribe({
        next: (response) => {
          this.customers = response.result.content;
          this.filteredCustomers = response.result.content;
        },
        error: (error) => {
          console.error('Error loading customers:', error);
        }
      })
    );
  }
  
  /**
   * Calculate statistics with multi-currency support
   */
  calculateStats(): void {
    // Calculate totals per currency
    const currencyMap = new Map<string, number>();
    
    this.loans
      .filter(l => l.status === 'ACTIVE' || l.status === 'OVERDUE')
      .forEach(loan => {
        const current = currencyMap.get(loan.currency) || 0;
        currencyMap.set(loan.currency, current + loan.amount);
      });
    
    this.currencyTotals = Array.from(currencyMap.entries()).map(([currency, total]) => ({
      currency,
      total
    }));
    
    // Get statistics from backend
    this.loanService.getLoanStatistics().subscribe({
      next: (response) => {
        this.activeLoansCount = response.result?.activeLoansCount || 0;
        this.overdueLoansCount = response.result?.overdueLoansCount || 0;
        this.repaidLoansCount = response.result?.repaidLoansCount || 0;
      },
      error: (error) => {
        console.error('Error fetching loan statistics:', error);
        // Fallback to local calculation
        this.activeLoansCount = this.loans.filter(l => l.status === 'ACTIVE').length;
        this.overdueLoansCount = this.loans.filter(l => l.status === 'OVERDUE').length;
        this.repaidLoansCount = this.loans.filter(l => l.status === 'REPAID').length;
      }
    });
  }
  
  /**
   * Search functionality
   */
  onSearch(): void {
    this.currentPage = 0;
    this.loadLoans();
  }
  
  /**
   * Status filter change
   */
  onStatusChange(status: string | null): void {
    this.statusFilter = status;
    this.currentPage = 0;
    this.loadLoans();
  }
  
  /**
   * Toggle advanced filters
   */
  toggleAdvancedFilters(): void {
    this.showAdvancedFilters = !this.showAdvancedFilters;
  }
  
  /**
   * Apply advanced filters
   */
  applyAdvancedFilters(): void {
    this.currentPage = 0;
    this.loadLoans();
  }
  
  /**
   * Reset all filters
   */
  resetFilters(): void {
    this.searchTerm = '';
    this.statusFilter = null;
    this.currencyFilter = 'all';
    this.amountMin = null;
    this.amountMax = null;
    this.currentPage = 0;
    this.loadLoans();
  }
  
  /**
   * Pagination
   */
  getPaginationRange(): number[] {
    const range: number[] = [];
    const maxPages = 5;
    
    if (this.totalPages <= maxPages) {
      for (let i = 0; i < this.totalPages; i++) {
        range.push(i);
      }
    } else {
      let start = Math.max(0, this.currentPage - Math.floor(maxPages / 2));
      let end = Math.min(this.totalPages - 1, start + maxPages - 1);
      
      if (end === this.totalPages - 1) {
        start = Math.max(0, end - maxPages + 1);
      }
      
      for (let i = start; i <= end; i++) {
        range.push(i);
      }
    }
    
    return range;
  }
  
  goToPage(page: number): void {
    if (page >= 0 && page < this.totalPages && page !== this.currentPage) {
      this.currentPage = page;
      this.loadLoans();
    }
  }
  
  /**
   * Open customer selection modal
   */
  openCustomerModal(): void {
    this.customerSearchTerm = '';
    this.loadCustomers();
    if (this.customerModal) {
      this.customerModal.show();
    }
  }
  
  /**
   * Filter customers - triggers backend search (debounced)
   */
  private filterCustomersDebounce: any;
  filterCustomers(): void {
    if (this.filterCustomersDebounce) clearTimeout(this.filterCustomersDebounce);
    this.filterCustomersDebounce = setTimeout(() => {
      this.loadCustomers(this.customerSearchTerm.trim() || undefined);
    }, 300);
  }
  
  /**
   * Clear customer search
   */
  clearCustomerSearch(): void {
    this.customerSearchTerm = '';
    this.loadCustomers();
  }
  
  /**
   * Select customer
   */
  selectCustomer(customer: User): void {
    this.selectedCustomer = customer;
    this.loanForm.patchValue({
      customerName: customer.fullName
    });
    
    if (this.customerModal) {
      this.customerModal.hide();
    }
    
    // Show loan modal after selecting customer
    setTimeout(() => {
      if (this.loanModal) {
        this.loanModal.show();
      }
    }, 300);
  }
  //go to link /customers with routerLink
  goToCustomers(): void {
    console.log("test");
    
    this.router.navigate(['/user-loans']);
  }
  
  /**
   * Open add customer modal
   */
  openAddCustomerModal(): void {
    this.customerForm.reset({
      fullName: '',
      cin: '',
      email: '',
      phoneNumber: '',
      address: ''
    });
    
    // Close customer selection modal
    if (this.customerModal) {
      this.customerModal.hide();
    }
    
    setTimeout(() => {
      if (this.addCustomerModal) {
        this.addCustomerModal.show();
      }
    }, 300);
  }
  
  /**
   * Save new customer
   */
  saveNewCustomer(): void {
    if (this.customerForm.invalid || this.savingCustomer) {
      Object.keys(this.customerForm.controls).forEach(key => {
        this.customerForm.get(key)?.markAsTouched();
      });
      return;
    }
    
    this.savingCustomer = true;
    
    const customerData: User = {
      fullName: this.customerForm.value.fullName,
      cin: this.customerForm.value.cin,
      email: this.customerForm.value.email,
      phoneNumber: this.customerForm.value.phoneNumber,
      address: this.customerForm.value.address
    };
    
    this.subscriptions.add(
      this.userService.saveUser(customerData).subscribe({
        next: (response) => {
          this.savingCustomer = false;
          
          if (this.addCustomerModal) {
            this.addCustomerModal.hide();
          }
          
          // Reload customers
          this.loadCustomers();
          
          // Auto-select the new customer
          setTimeout(() => {
            const newCustomer = response.result;
            this.toast.showSuccess(this.languageService.translate('loan.customer-added'));
            this.selectCustomer(newCustomer);
          }, 500);
        },
        error: (err) => {
          this.savingCustomer = false;
          const backend = err?.error || err;
          let messages: string[] = [];
          
          if (backend?.errorMap) {
            messages = Object.entries(backend.errorMap)
              .map(([k, v]) => `${k}: ${v}`);
          } else if (Array.isArray(backend?.errors)) {
            messages = backend.errors.map((e: any) => e.message || 'Unknown error');
          } else if (backend?.message) {
            messages = [backend.message];
          } else {
            messages = ['Erreur serveur'];
          }
          
          this.toast.showError(messages.join('\n'));
        }
      })
    );
  }
  
  /**
   * Show new loan modal - FIXED: Opens customer selection first
   */
  showNewLoan(): void {
    this.formMode = 'add';
    this.selectedCustomer = null;
    this.editingLoanId = null;
    
    this.loanForm.reset({
      customerName: '',
      amount: '',
      currency: 'MAD',
      loanType: '',
      lenderName: '',
      exchangeRate: null,
      issueDate: new Date().toISOString().split('T')[0],
      dueDate: '',
      interestRate: 0,
      collateral: '',
      notes: '',
      isConfidential: false,
      status: 'ACTIVE'
    });
    
    // Open customer selection modal instead of loan modal
    this.openCustomerModal();
  }
  
  /**
   * Format date for input
   */
  formatForDateInput(date: any): string {
    if (!date) return '';
    const d = new Date(date);
    // Check for invalid date or epoch date
    if (isNaN(d.getTime()) || d.getFullYear() < 1971) return '';
    const year = d.getFullYear();
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  }
  
  /**
   * Edit loan
   */
  editLoan(loan: Loan): void {
    this.formMode = 'edit';
    this.editingLoanId = loan.id;
    
    // Find and set customer
    const customer = this.customers.find(c => c.fullName === loan.customerName);
    this.selectedCustomer = customer || {
      fullName: loan.customerName,
      email: loan.email || '',
      cin: loan.cin || '',
      phoneNumber: loan.phoneNumber || '',
      address: '',
      id: loan.id
    };
    
    this.loanForm.patchValue({
      customerName: loan.customerName,
      amount: loan.amount,
      currency: loan.currency,
      issueDate: this.formatForDateInput(loan.issueDate),
      dueDate: this.formatForDateInput(loan.dueDate),
      interestRate: loan.interestRate,
      collateral: loan.collateral,
      notes: loan.notes,
      isConfidential: loan.isConfidential,
      status: loan.status
    });
    
    setTimeout(() => {
      if (this.loanModal) {
        this.loanModal.show();
      }
    }, 100);
  }
  
  /**
   * Save loan
   */
  saveLoan(): void {
    if (this.loanForm.invalid || !this.selectedCustomer || this.savingLoan) {
      Object.keys(this.loanForm.controls).forEach(key => {
        this.loanForm.get(key)?.markAsTouched();
      });
      
      if (!this.selectedCustomer) {
        this.toast.showError(this.languageService.translate('loan.error-select-customer'));
      }
      return;
    }
    
    this.savingLoan = true;
    const formValue = this.loanForm.value;
    
    const loanData: Loan = {
      id: this.formMode === 'edit' ? this.editingLoanId! : 0,
      customerName: this.selectedCustomer.fullName,
      cin: this.selectedCustomer.cin || '',
      customerId: this.selectedCustomer.id?.toString() || '',
      email: this.selectedCustomer.email,
      phoneNumber: this.selectedCustomer.phoneNumber,
      amount: formValue.amount,
      currency: formValue.currency,
      loanType: formValue.loanType || undefined,
      lenderName: formValue.lenderName || undefined,
      exchangeRate: formValue.exchangeRate ?? undefined,
      issueDate: new Date(formValue.issueDate),
      dueDate: formValue.dueDate ? new Date(formValue.dueDate) : null,
      status: this.formMode === 'edit' ? formValue.status : 'ACTIVE',
      interestRate: formValue.interestRate || 0,
      collateral: formValue.collateral || '',
      notes: formValue.notes || '',
      isConfidential: formValue.isConfidential || false
    };
    
    const serviceCall = this.formMode === 'add' 
      ? this.loanService.saveLoan(loanData) 
      : this.loanService.updateLoan(loanData);
    
    this.subscriptions.add(
      serviceCall.subscribe({
        next: (response: any) => {
          this.savingLoan = false;
          this.hideModal();
          
          // Use backend message if available, otherwise use translation
          const defaultKey = this.formMode === 'add' ? 'loan.success-created' : 'loan.success-updated';
          const message = response?.message || this.languageService.translate(defaultKey);
          
          this.toast.showSuccess(message);
          
          setTimeout(() => {
            this.loadLoans();
          }, 300);
        },
        error: (error) => {
          console.error('Error saving loan:', error);
          this.savingLoan = false;
          const errorMsg = this.extractErrorMessage(error);
          this.toast.showError(errorMsg);
        }
      })
    );
  }
  
  /**
   * Delete loan
   */
  deleteLoan(loan: Loan): void {
    this.modalTitle = this.languageService.translate('loan.modal-delete-title');
    this.modalBody = this.languageService.translate('loan.modal-delete-body').replace('{name}', loan.customerName);
    this.modalConfirmText = this.languageService.translate('loan.delete');
    this.modalHeaderClass = 'bg-danger text-white';
    this.modalButtonClass = 'btn btn-danger';
    this.modalAction = 'delete';
    this.editingLoanId = loan.id;
    
    if (this.confirmModal) {
      this.confirmModal.show();
    }
  }
  
  /**
   * Mark as repaid
   */
  markAsRepaid(loan: Loan): void {
    this.modalTitle = this.languageService.translate('loan.modal-repaid-title');
    this.modalBody = this.languageService.translate('loan.modal-repaid-body').replace('{name}', loan.customerName);
    this.modalConfirmText = this.languageService.translate('loan.confirm');
    this.modalHeaderClass = 'bg-success text-white';
    this.modalButtonClass = 'btn btn-success';
    this.modalAction = 'repaid';
    this.editingLoanId = loan.id;
    
    if (this.confirmModal) {
      this.confirmModal.show();
    }
  }
  
  /**
   * Handle modal confirmation
   */
  handleModalConfirm(): void {
    if (!this.editingLoanId || this.loading) return;
    
    this.loading = true;
    
    if (this.modalAction === 'delete') {
      this.subscriptions.add(
        this.loanService.deleteLoan(this.editingLoanId).subscribe({
          next: (response: any) => {
            this.loading = false;
            if (this.confirmModal) this.confirmModal.hide();
            const message = response?.message || this.languageService.translate('loan.success-deleted');
            this.toast.showSuccess(message);
            setTimeout(() => this.loadLoans(), 300);
          },
          error: (error) => {
            console.error('Error deleting loan:', error);
            this.loading = false;
            const errorMsg = this.extractErrorMessage(error);
            this.toast.showError(errorMsg);
          }
        })
      );
    } else if (this.modalAction === 'repaid') {
      this.subscriptions.add(
        this.loanService.updateStatus(this.editingLoanId, 'REPAID').subscribe({
          next: (response: any) => {
            this.loading = false;
            if (this.confirmModal) this.confirmModal.hide();
            const message = response?.message || this.languageService.translate('loan.success-repaid');
            this.toast.showSuccess(message);
            setTimeout(() => this.loadLoans(), 300);
          },
          error: (error) => {
            console.error('Error updating status:', error);
            this.loading = false;
            const errorMsg = this.extractErrorMessage(error);
            this.toast.showError(errorMsg);
          }
        })
      );
    }
    
    this.modalAction = null;
    this.editingLoanId = null;
  }
  
  /**
   * Extract error message from API error response
   */
  private extractErrorMessage(error: any): string {
    const backend = error?.error || error;
    
    if (backend?.errors && Array.isArray(backend.errors)) {
      const lang = this.languageService.getCurrentLanguage();
      const errorObj = backend.errors[0];
      if (lang === 'francais' && errorObj?.messageFr) return errorObj.messageFr;
      if (lang === 'english' && errorObj?.messageEn) return errorObj.messageEn;
      if (lang === 'arabic' && errorObj?.messageAr) return errorObj.messageAr || errorObj.messageFr;
      return errorObj?.message || errorObj?.messageFr || errorObj?.messageEn || 'Error';
    }
    
    if (backend?.message) return backend.message;
    
    return this.languageService.translate('loan.error-updating');
  }
  
  /**
   * Hide modal
   */
  hideModal(): void {
    if (this.loanModal) {
      this.loanModal.hide();
    }
    
    setTimeout(() => {
      const backdrop = document.querySelector('.modal-backdrop');
      if (backdrop) backdrop.remove();
      document.body.classList.remove('modal-open');
      document.body.style.overflow = '';
      document.body.style.paddingRight = '';
    }, 200);
  }
  
  /**
   * Utility: Format amount
   */
  formatAmount(amount: number, currency: string): string {
    return new Intl.NumberFormat('fr-MA', {
      style: 'currency',
      currency: currency
    }).format(amount);
  }
  
  /**
   * Utility: Format date
   */
  formatDate(date: Date | null | undefined): string {
    if (!date) return '-';
    const d = new Date(date);
    // Check for invalid date or epoch date (1970)
    if (isNaN(d.getTime()) || d.getFullYear() < 1971) return '-';
    return d.toLocaleDateString('fr-FR', {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    });
  }
  
  /**
   * Utility: Get initials
   */
  getInitials(name?: string): string {
    if (!name || typeof name !== 'string') return '';
    return name
      .trim()
      .split(' ')
      .filter(x => x.length > 0)
      .map(x => x[0])
      .join('')
      .toUpperCase();
  }
  
  /**
   * Utility: Get status badge class
   */
  getStatusBadgeClass(status: string): string {
    switch (status) {
      case 'ACTIVE': return 'badge badge-primary';
      case 'REPAID': return 'badge badge-success';
      case 'OVERDUE': return 'badge badge-danger';
      case 'CANCELED': return 'badge badge-secondary';
      default: return 'badge badge-secondary';
    }
  }
  
  /** Montant restant dû (amount - paidAmount) */
  getRemaining(loan: Loan): number {
    return getLoanRemaining(loan);
  }

  /**
   * Utility: Check if due soon
   */
  isDueSoon(dueDate: Date | null | undefined): boolean {
    if (!dueDate) return false;
    const today = new Date();
    const due = new Date(dueDate);
    // Check for invalid date
    if (isNaN(due.getTime()) || due.getFullYear() < 1971) return false;
    const sevenDaysFromNow = new Date();
    sevenDaysFromNow.setDate(today.getDate() + 7);
    return due > today && due <= sevenDaysFromNow;
  }
}


