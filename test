                            <th>{{ 'loan.cin' | translate }}</th>
                            <th>{{ 'loan.email' | translate }}</th>
                            <th>{{ 'loan.phone' | translate }}</th>
                            <th>{{ 'loan.address' | translate }}</th>
                            <th>{{ 'loan.credits' | translate }}</th>
                            <th class="text-center">{{ 'loan.actions' | translate }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr *ngFor="let user of filteredUsers" class="fade-in">
                            <td>#{{ user.id }}</td>

                            <td>
                                <div class="customer-cell">
                                    <div class="customer-avatar">
                                        {{ getInitials(user.fullName) }}
                                    </div>
                                    <span class="customer-name">{{ user.fullName }}</span>
                                </div>
                            </td>

                            <td>{{ user.cin || '—' }}</td>

                            <td>
                                <i class="fas fa-envelope text-muted me-1"></i>
                                {{ user.email }}
                            </td>

                            <td>
                                <i class="fas fa-phone text-muted me-1"></i>
                                {{ user.phoneNumber }}
                            </td>

                            <td>
                                <i class="fas fa-map-marker-alt text-muted me-1"></i>
                                {{ user.address }}
                            </td>

                            <td>
                                <span [class]="getStatusBadgeClass(user.activeLoansCount || 0)">
                                    {{ user.activeLoansCount || 0 }} {{ 'loan.active-count' | translate }}
                                </span>
                            </td>

                            <td>
                                <div class="action-buttons">
                                    <button class="btn-action btn-view" (click)="viewUser(user)" title="Voir détails">
                                        <i class="fas fa-eye"></i>
                                    </button>

                                    <button class="btn-action btn-edit" (click)="editUser(user)" [title]="'loan.edit' | translate">
                                        <i class="fas fa-edit"></i>
                                    </button>

                                    <button class="btn-action btn-delete" (click)="deleteUser(user)" [title]="'loan.delete' | translate">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>

                        <tr *ngIf="filteredUsers.length === 0 && !loading">
                            <td colspan="8" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="fas fa-users fa-3x mb-3"></i>
                                    <p>Aucun client trouvé</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="pagination-container" *ngIf="totalPages > 1">
                <div class="pagination-info">
                    Affichage {{ (currentPage * itemsPerPage) + 1 }} -
                    {{ Math.min((currentPage + 1) * itemsPerPage, totalElements) }}
                    sur {{ totalElements }}
                </div>

                <nav>
                    <ul class="pagination">
                        <li class="page-item" [class.disabled]="currentPage === 0">
                            <a class="page-link" (click)="goToPage(currentPage - 1)">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>

                        <li *ngFor="let page of getPaginationRange()" class="page-item"
                            [class.active]="page === currentPage">
                            <a class="page-link" (click)="goToPage(page)">{{ page + 1 }}</a>
                        </li>

                        <li class="page-item" [class.disabled]="currentPage === totalPages - 1">
                            <a class="page-link" (click)="goToPage(currentPage + 1)">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- User Modal (Add/Edit) -->
<div class="modal fade user-modal" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-user me-2"></i>
                    {{ formMode === 'add' ? ('loan.new-client' | translate) : ('loan.edit-client' | translate) }}
                </h5>
                <button type="button" class="btn-close" (click)="hideModal()"></button>
            </div>

            <form [formGroup]="userForm" (ngSubmit)="saveUser()">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">{{ 'loan.full-name' | translate }} *</label>
                            <input type="text" class="form-control" formControlName="fullName"
                                [placeholder]="'loan.full-name' | translate" />
                            <div class="invalid-feedback"
                                *ngIf="userForm.get('fullName')?.invalid && userForm.get('fullName')?.touched">
                                {{ 'loan.full-name-required' | translate }}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.client-type' | translate }}</label>
                            <select class="form-select" formControlName="clientType">
                                <option value="PARTICULIER">{{ 'loan.client-type-particulier' | translate }}</option>
                                <option value="INSTITUTION">{{ 'loan.client-type-institution' | translate }}</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.cin' | translate }} <span *ngIf="userForm.get('clientType')?.value === 'PARTICULIER'">*</span></label>
                            <input type="text" class="form-control" formControlName="cin" [placeholder]="'loan.cin-placeholder' | translate" />
                            <div class="invalid-feedback"
                                *ngIf="userForm.get('cin')?.invalid && userForm.get('cin')?.touched">
                                {{ 'loan.cin-required' | translate }}
                            </div>
                            <small class="text-muted" *ngIf="userForm.get('clientType')?.value === 'INSTITUTION'">{{ 'loan.cin-optional-institution' | translate }}</small>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.phone' | translate }} *</label>
                            <input type="text" class="form-control" formControlName="phoneNumber"
                                [placeholder]="'loan.phone' | translate" />
                            <div class="invalid-feedback"
                                *ngIf="userForm.get('phoneNumber')?.invalid && userForm.get('phoneNumber')?.touched">
                                {{ 'loan.phone-required' | translate }}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">{{ 'loan.email' | translate }} *</label>
                            <input type="email" class="form-control" formControlName="email"
                                [placeholder]="'loan.email' | translate" />
                            <div class="invalid-feedback"
                                *ngIf="userForm.get('email')?.invalid && userForm.get('email')?.touched">
                                {{ 'loan.email-required' | translate }}
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label">{{ 'loan.address' | translate }} *</label>
                            <textarea class="form-control" formControlName="address" rows="2"
                                [placeholder]="'loan.address' | translate"></textarea>
                            <div class="invalid-feedback"
                                *ngIf="userForm.get('address')?.invalid && userForm.get('address')?.touched">
                                {{ 'loan.address-required' | translate }}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" (click)="hideModal()">
                        {{ 'loan.cancel' | translate }}
                    </button>
                    <button type="submit" class="btn btn-primary" [disabled]="savingUser">
                        <span *ngIf="savingUser">
                            <i class="fas fa-spinner fa-spin me-2"></i>
                            {{ 'common.saving' | translate }}
                        </span>
                        <span *ngIf="!savingUser">
                            <i class="fas fa-save me-2"></i>
                            {{ formMode === 'add' ? ('loan.create' | translate) : ('loan.save' | translate) }}
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

