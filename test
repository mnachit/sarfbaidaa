    @Override
    public PageResponse<LoanResponse> getAllLoans(Company company, Pageable pageable,
                                                   String status, String currency, Long clientId,
                                                   String startDate, String endDate, String search, Long userId) {
        LoanStatus statusEnum = null;
        if (status != null && !status.isBlank() && !"all".equalsIgnoreCase(status)) {
            try {
                statusEnum = LoanStatus.valueOf(status.toUpperCase());
            } catch (IllegalArgumentException ignored) {}
        }

        String currencyCode = (currency != null && !currency.isBlank() && !"all".equalsIgnoreCase(currency)) ? currency : null;
        LocalDate start = parseDate(startDate);
        LocalDate end = parseDate(endDate);

        Sort sort = Sort.by(Sort.Direction.DESC, "createdAt");
        Pageable sortedPageable = PageRequest.of(pageable.getPageNumber(), pageable.getPageSize(), sort);

        Page<Loan> page;
        if (statusEnum != null || currencyCode != null || clientId != null || start != null || end != null) {
            page = loanRepository.findFiltered(company, statusEnum, currencyCode, clientId, start, end, sortedPageable);
        } else {
            page = loanRepository.findByCompany(company, sortedPageable);
        }

        // Filter by userId - only show loans created by this user
        List<Loan> content = page.getContent().stream()
                .filter(loan -> loan.getCreatedBy() != null && loan.getCreatedBy().getId().equals(userId))
                .collect(Collectors.toList());
                
        if (search != null && !search.isBlank()) {
            String s = search.toLowerCase();
            content = content.stream()
                    .filter(l -> (l.getClient().getFullName() != null && l.getClient().getFullName().toLowerCase().contains(s)) ||
                            (l.getClient().getCin() != null && l.getClient().getCin().toLowerCase().contains(s)) ||
                            (l.getClient().getEmail() != null && l.getClient().getEmail().toLowerCase().contains(s)) ||
                            (l.getCurrency().getCode() != null && l.getCurrency().getCode().toLowerCase().contains(s)))
                    .collect(Collectors.toList());
        }

        List<LoanResponse> responses = content.stream().map(this::toLoanResponse).collect(Collectors.toList());

        return PageResponse.<LoanResponse>builder()
                .content(responses)
                .currentPage(page.getNumber())
                .pageSize(page.getSize())
                .totalElements((long) content.size())
                .totalPages((int) Math.ceil((double) content.size() / page.getSize()))
                .hasNext(page.hasNext())
                .hasPrevious(page.hasPrevious())
                .build();
    }

