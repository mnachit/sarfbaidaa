    @Override
    public List<UserLoanResponse> getMyClients(Company company, Long userId) {
        // Get all loans created by this user
        List<Loan> myLoans = loanRepository.findByCompany(company).stream()
                .filter(loan -> loan.getCreatedBy() != null && loan.getCreatedBy().getId().equals(userId))
                .collect(Collectors.toList());
        
        // Extract unique clients and calculate totals for each
        Map<Long, LoanClient> uniqueClients = new LinkedHashMap<>();
        Map<Long, BigDecimal> totalAmounts = new HashMap<>();
        Map<Long, BigDecimal> totalPaid = new HashMap<>();
        Map<Long, Integer> loanCounts = new HashMap<>();
        
        for (Loan loan : myLoans) {
            LoanClient client = loan.getClient();
            if (client != null) {
                Long clientId = client.getId();
                uniqueClients.putIfAbsent(clientId, client);
                totalAmounts.merge(clientId, loan.getAmount(), BigDecimal::add);
                totalPaid.merge(clientId, loan.getPaidAmount(), BigDecimal::add);
                loanCounts.merge(clientId, 1, Integer::sum);
            }
        }
        
        // Convert to response DTOs
        return uniqueClients.entrySet().stream()
                .map(entry -> {
                    LoanClient client = entry.getValue();
                    Long clientId = client.getId();
                    return UserLoanResponse.builder()
                            .id(clientId)
                            .fullName(client.getFullName())
                            .cin(client.getCin())
                            .email(client.getEmail())
                            .phoneNumber(client.getPhoneNumber())
                            .address(client.getAddress())
                            .totalLoans(loanCounts.getOrDefault(clientId, 0))
                            .totalAmount(totalAmounts.getOrDefault(clientId, BigDecimal.ZERO))
                            .totalPaid(totalPaid.getOrDefault(clientId, BigDecimal.ZERO))
                            .totalRemaining(totalAmounts.getOrDefault(clientId, BigDecimal.ZERO)
                                    .subtract(totalPaid.getOrDefault(clientId, BigDecimal.ZERO)))
                            .build();
                })
                .collect(Collectors.toList());
    }

    @Override
    public LoanPaymentDto addPayment(Long loanId, LoanPaymentRequest request, Company company, Long createdByUserId) {
        // Fetch loan and validate ownership
        Loan loan = getLoanWithOwnershipCheck(loanId, company, createdByUserId);

        if (loan.getStatus() == LoanStatus.REPAID) {
            throw new ValidationException(List.of(
                    ErrorMessage.builder().status(400).messageFr("Ce crédit est déjà remboursé").messageEn("Loan is already repaid").build()));
        }

        BigDecimal remaining = loan.getAmount().subtract(loan.getPaidAmount());
        if (request.getAmount().compareTo(remaining) > 0) {
            throw new ValidationException(List.of(
                    ErrorMessage.builder().status(400).messageFr("Le montant dépasse le solde restant").messageEn("Amount exceeds remaining balance").build()));
        }

        User createdBy = createdByUserId != null ? userRepository.findById(createdByUserId).orElse(null) : null;

        LoanPayment payment = LoanPayment.builder()
                .loan(loan)
                .amount(request.getAmount())
                .paymentDate(java.sql.Date.valueOf(request.getPaymentDate()))
                .notes(request.getNotes())
                .createdBy(createdBy)
                .build();

        payment = loanPaymentRepository.save(payment);

        loan.setPaidAmount(loan.getPaidAmount().add(request.getAmount()));
        if (loan.getPaidAmount().compareTo(loan.getAmount()) >= 0) {
            loan.setStatus(LoanStatus.REPAID);
        }
        loanRepository.save(loan);

        return LoanPaymentDto.builder()
                .id(payment.getId())
                .loanId(loanId)
                .amount(payment.getAmount())
                .paymentDate(payment.getPaymentDate().toInstant().atZone(ZoneId.systemDefault()).toLocalDate())
                .notes(payment.getNotes())
                .createdAt(payment.getCreatedAt().toInstant().atZone(ZoneId.systemDefault()).toLocalDateTime())
                .build();
    }

